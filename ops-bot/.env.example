# ── 텔레그램 봇 ──
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_TELEGRAM_USER_IDS=your_telegram_user_id
ALLOWED_TELEGRAM_CHAT_IDS=your_telegram_chat_id

# ── JWT 검증용 관리자 계정 ──
OPS_LOGIN_ID=admin@example.com
OPS_LOGIN_PW=your_admin_password_here

# ── DB 백업 ──
DB_PASSWORD=your_db_password_here
DB_HOST=192.168.120.18

# ── 서버 접속 ──
OPS_SSH_KEY=/home/ubuntu/.ssh/haehan-ai.pem
OPS_SSH_HOST=ubuntu@server_ip_here
OPS_APP_DIR=/home/ubuntu/app/attendance

# ── 운영 도메인 ──
OPS_BASE_URL=https://attendance.haehan-ai.kr
