# ═══════════════════════════════════════════════════════════
#  해한 현장 출퇴근 시스템 — 환경변수 템플릿
#  cp .env.example .env 후 실제 값으로 채우세요.
#  .env 는 절대 Git 에 커밋하지 마세요.
# ═══════════════════════════════════════════════════════════

# ─── 앱 기본 ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000

NEXT_PUBLIC_APP_NAME="해한 현장 출퇴근"
NEXT_PUBLIC_BASE_URL="https://your-domain.com"

# ─── 데이터베이스 ──────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/construction_attendance"

# ─── JWT 인증 ──────────────────────────────────────────────
# 최소 64자 이상 랜덤 문자열 생성: openssl rand -base64 64
JWT_SECRET="CHANGE-THIS-TO-A-VERY-LONG-RANDOM-STRING-AT-LEAST-64-CHARS"
JWT_EXPIRES_IN="7d"

# ─── OTP 설정 ─────────────────────────────────────────────
OTP_EXPIRES_MINUTES=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_LENGTH=6

# ─── SMS 설정 ─────────────────────────────────────────────
# SMS_MODE: mock | coolsms | ncloud
# mock = 콘솔에 OTP 출력 (개발/테스트 전용, 운영 시 반드시 변경)
SMS_MODE="mock"
ENABLE_MOCK_SMS=true

# 발신 번호 (모든 provider 공통)
SMS_FROM_NUMBER="01000000000"

# --- CoolSMS (SMS_MODE=coolsms 일 때만 사용) ---
COOLSMS_API_KEY=""
COOLSMS_API_SECRET=""
COOLSMS_SENDER_PHONE=""

# --- NCloud SENS (SMS_MODE=ncloud 일 때만 사용) ---
NCLOUD_ACCESS_KEY=""
NCLOUD_SECRET_KEY=""
NCLOUD_SMS_SERVICE_ID=""
NCLOUD_SENDER_PHONE=""

# ─── GPS / 출퇴근 정책 ─────────────────────────────────────
# 현장 등록 시 기본 허용 반경 (m)
DEFAULT_SITE_RADIUS_M=100

# GPS 오차 추가 여유 (m) — 현장 allowedRadius 에 더해짐
GPS_EXTRA_TOLERANCE=0

# GPS 엄격 모드: true=반경 초과 시 완전 차단 / false=예외 요청 유도
GPS_STRICT_MODE=true

# 예외 요청 허용 여부
ALLOW_EXCEPTION_REQUEST=true

# 출근 허용 시작 시각 (24h KST), 미설정 시 제한 없음
CHECKIN_ALLOWED_START_TIME="05:00"

# 퇴근 허용 마감 시각 (24h KST), 미설정 시 제한 없음
CHECKOUT_ALLOWED_END_TIME="23:59"

# ─── 관리자 초기 계정 ──────────────────────────────────────
# seed 시 생성. 운영 반영 후 즉시 비밀번호 변경할 것
ADMIN_INITIAL_PASSWORD="CHANGE-THIS-BEFORE-PRODUCTION"

# ─── 자동 퇴근 처리 스케줄러 ───────────────────────────────
# POST /api/cron/auto-checkout 을 호출하는 Bearer 토큰
# 생성: openssl rand -base64 32
CRON_SECRET="CHANGE-THIS-TO-A-RANDOM-SECRET"

# 매일 04:00 KST 실행 (서버 시각 UTC 기준 19:00)
# crontab 예시:
#   0 19 * * * curl -s -X POST http://localhost:3000/api/cron/auto-checkout \
#     -H "Authorization: Bearer $CRON_SECRET" >> /var/log/auto-checkout.log 2>&1
# dry-run 테스트:
#   curl -s -X POST "http://localhost:3000/api/cron/auto-checkout?dryRun=true" \
#     -H "Authorization: Bearer $CRON_SECRET"

# ─── 이메일 (SMTP) ────────────────────────────────────────
# 설정하지 않으면 이메일 발송 없이 동작 (콘솔 경고만 출력)
# 예시: Gmail 앱 비밀번호 사용 시
#   EMAIL_HOST=smtp.gmail.com
#   EMAIL_PORT=587
#   EMAIL_SECURE=false
#   EMAIL_USER=your-address@gmail.com
#   EMAIL_PASS=xxxx-xxxx-xxxx-xxxx  (앱 비밀번호)
#   EMAIL_FROM="현장출근관리 <no-reply@your-domain.com>"

EMAIL_HOST=""
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM=""

# ─── 카카오 지도 / 지오코딩 ───────────────────────────────
# 카카오 개발자 콘솔 → 내 애플리케이션 → 앱 키
# JavaScript 키 (프론트 공개): 지도 SDK 로드용
NEXT_PUBLIC_KAKAO_MAP_JS_KEY="카카오_JavaScript_키_입력"
# REST API 키 (서버 전용): 주소→좌표 변환용 (절대 프론트 노출 금지)
KAKAO_REST_API_KEY="카카오_REST_API_키_입력"
# 카카오 OAuth 로그인 (NextAuth)
KAKAO_CLIENT_ID="카카오_앱_REST_API_키"
KAKAO_CLIENT_SECRET="카카오_보안_키"

# ─── 구글 OAuth 로그인 (NextAuth) ─────────────────────────
GOOGLE_CLIENT_ID="구글_클라이언트_ID"
GOOGLE_CLIENT_SECRET="구글_클라이언트_시크릿"
NEXTAUTH_URL="https://your-domain.com"
NEXTAUTH_SECRET="CHANGE-THIS-TO-A-RANDOM-SECRET"
ADMIN_EMAILS="admin@example.com"

# ─── 로깅 / 운영 ──────────────────────────────────────────
LOG_LEVEL=warn
ENABLE_SEED_IN_PRODUCTION=false
