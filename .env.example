# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/construction_attendance"

# ─── Auth ────────────────────────────────────────────────
# JWT secret (최소 32자 이상의 랜덤 문자열)
JWT_SECRET="change-this-to-a-very-long-random-secret-string"
JWT_EXPIRES_IN="7d"

# ─── OTP ─────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=5

# SMS 모드: "mock" 이면 실제 발송 없이 콘솔에 출력
SMS_MODE="mock"  # mock | coolsms | ncloud

# CoolSMS
COOLSMS_API_KEY=""
COOLSMS_API_SECRET=""
COOLSMS_SENDER_PHONE=""

# NCloud SMS (SENS)
NCLOUD_ACCESS_KEY=""
NCLOUD_SECRET_KEY=""
NCLOUD_SMS_SERVICE_ID=""
NCLOUD_SENDER_PHONE=""

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="해한 현장 출퇴근"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# 관리자 초기 비밀번호 (seed 시 사용)
ADMIN_INITIAL_PASSWORD="change-this-in-production"

# ─── GPS ─────────────────────────────────────────────────
# GPS 허용 오차 추가 여유 (m) — 현장 반경에 더해짐
GPS_EXTRA_TOLERANCE=0
