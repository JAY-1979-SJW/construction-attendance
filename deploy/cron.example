# ──────────────────────────────────────────────
# cron.example — scheduled_check.sh 자동 실행 등록 예시
#
# 적용 방법:
#   crontab -e
#   아래 내용 붙여넣기 후 PROJECT_DIR 경로 실제 경로로 수정
#
# 로그는 logs/ 디렉터리에 자동 저장됨 (scheduled_check.sh 내부 처리)
# ──────────────────────────────────────────────

PROJECT_DIR=/home/ubuntu/app/attendance

# 빠른 점검: 매 5분 (health + 주요 페이지)
*/5 * * * * cd $PROJECT_DIR && bash scripts/scheduled_check.sh --quick >> /dev/null 2>&1

# 전체 점검: 매 시간 정각 (웹 + 시나리오 + 컨테이너)
0 * * * * cd $PROJECT_DIR && bash scripts/scheduled_check.sh --full >> /dev/null 2>&1

# DB 백업: 매일 새벽 3시
0 3 * * * cd $PROJECT_DIR/ops-bot && bash scripts/backup_db.sh db >> /dev/null 2>&1

# 근무확정 월별 자동처리: 매월 1일 오전 1시 KST (= 16:00 UTC 전달 말일)
# generate → auto-confirm (NORMAL+FULL_DAY) → 검토대기 집계
# finalize는 실행하지 않음 — 수동 승인 필요
0 16 28-31 * * [ "$(date -d tomorrow +\%d)" = "01" ] && curl -s -X POST http://localhost:3002/api/cron/work-confirm-monthly -H "x-cron-secret: $CRON_SECRET" >> $PROJECT_DIR/logs/work-confirm-monthly.log 2>&1

# ──────────────────────────────────────────────
# systemd 방식 (선택)
# /etc/systemd/system/attendance-check.service 참고
# ──────────────────────────────────────────────
