# ──────────────────────────────────────────────
# ops-bot/.env 예시
# 실제 파일: ops-bot/.env  (gitignore 적용됨)
# ──────────────────────────────────────────────

# 텔레그램 봇 인증 (telegram.sh 겸용 가능)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ops-bot 접근 허용 사용자/채팅 ID (쉼표 구분)
ALLOWED_TELEGRAM_USER_IDS=123456789
ALLOWED_TELEGRAM_CHAT_IDS=123456789

# DB 백업용 패스워드 (backup_db.sh)
DB_PASSWORD=your_db_password_here
DB_HOST=192.168.120.18

# JWT 검증용 관리자 계정 (check_jwt_runtime.sh)
OPS_LOGIN_ID=admin@example.com
OPS_LOGIN_PW=your_admin_password_here
