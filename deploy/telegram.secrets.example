# ──────────────────────────────────────────────
# telegram.secrets.example
# 실제 파일: ~/.config/ops/telegram.secrets
# 저장 후 chmod 600 ~/.config/ops/telegram.secrets
# ──────────────────────────────────────────────
# 텔레그램 봇 토큰 (BotFather에서 발급)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 알림 대상 채팅 ID
TELEGRAM_CHAT_ID=your_chat_id_here
