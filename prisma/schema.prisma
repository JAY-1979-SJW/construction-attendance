  // 현장 운영 기록 (v3)
  notices                    SiteNotice[]
  dailySchedules             SiteDailySchedule[]
  workLogs                   SiteWorkLog[]
  dailyWorkerStatuses        SiteDailyWorkerStatus[]
  tbmRecords                 SiteTbmRecord[]
  workLogSummaries           SiteWorkLogSummary[]
  accessGroupSites           SiteAccessGroupSite[]
  estimateDocuments          EstimateDocument[]
  materialRequests           MaterialRequest[]
  purchaseOrders             PurchaseOrder[]
  // 근로자 작업일보
  workerDailyReports         WorkerDailyReport[]
  locationMasters            SiteLocationMaster[]
  // 투입 전 필수 문서 패키지
