  industrialAccidentEligible   Boolean @default(true)
  industrialAccidentReason     String?
  calculationSnapshotJson      Json?
  createdAt                    DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, monthKey])
  @@index([monthKey])
  @@map("insurance_eligibility_snapshots")
}

model WageCalculation {
  id                      String     @id @default(cuid())
  workerId                String
  monthKey                String     // 'YYYY-MM'
  incomeType              IncomeType
  regularDays             Decimal    @default(0) @db.Decimal(6, 2)
  halfDays                Decimal    @default(0) @db.Decimal(6, 2)
  overtimeMinutes         Int        @default(0)
  nightMinutes            Int        @default(0)
