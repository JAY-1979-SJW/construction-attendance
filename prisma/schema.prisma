  presenceCheckFailureNeedsReview   Boolean  @default(true)
  presenceCheckAmStart              String   @default("09:30")
  presenceCheckAmEnd                String   @default("11:30")
  presenceCheckPmStart              String   @default("13:30")
  presenceCheckPmEnd                String   @default("16:30")
