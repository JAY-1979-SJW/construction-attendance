// ─── EXTERNAL_SITE_ADMIN 접근 그룹 ───────────────────────────────────────────

// 현장 접근 그룹 — 복수의 현장(회사 경계 초월 가능)을 하나의 접근 단위로 묶음
// EXTERNAL_SITE_ADMIN 에게 UserSiteAccessGroup 으로 할당
model SiteAccessGroup {
  id              String    @id @default(cuid())
  name            String    // 그룹 이름 (예: "A건설 2026 협력사 그룹")
  description     String?
  ownerCompanyId  String?   // 그룹 소유 업체 (null=플랫폼 소유)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sites SiteAccessGroupSite[]
  users UserSiteAccessGroup[]

  @@index([ownerCompanyId])
  @@map("site_access_groups")
}

// 접근 그룹 ↔ 현장 매핑
model SiteAccessGroupSite {
  id            String   @id @default(cuid())
  accessGroupId String
  siteId        String
  addedAt       DateTime @default(now())
  addedBy       String

  accessGroup SiteAccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)
  site        Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([accessGroupId, siteId])
  @@index([siteId])
  @@map("site_access_group_sites")
}

// 사용자 ↔ 접근 그룹 매핑 (EXTERNAL_SITE_ADMIN 역할 사용자를 특정 그룹에 할당)
model UserSiteAccessGroup {
  id            String    @id @default(cuid())
  userId        String
  accessGroupId String
  isActive      Boolean   @default(true)
  assignedAt    DateTime  @default(now())
  assignedBy    String
  revokedAt     DateTime?
  revokedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user        AdminUser       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessGroup SiteAccessGroup @relation(fields: [accessGroupId], references: [id], onDelete: Cascade)

  @@unique([userId, accessGroupId])
  @@index([userId, isActive])
  @@index([accessGroupId])
  @@map("user_site_access_groups")
}

// ─── v2: Worker-Site 배정 이력 ────────────────────────────

model WorkerSiteAssignment {
  id           String    @id @default(cuid())
  workerId     String
  siteId       String
  companyId    String
  assignedFrom DateTime
  assignedTo   DateTime?
  tradeType    String?   // 공종
  wageType     String?   // 급여형태: DAILY(일급), MONTHLY(월급), BUSINESS_INCOME(사업소득)
  workType     String?   // 근무형태: DAILY(일용직), REGULAR(상용직), FIXED_TERM(기간제), OUTSOURCED(외주)
  isPrimary    Boolean   @default(false)
