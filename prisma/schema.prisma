  @@index([jobId, dedupeStatus])
  @@index([jobId, validationStatus])
  @@map("bulk_worker_import_rows")
}

// ─── v2: 범용 감사 로그 ──────────────────────────────────

model AuditLog {
  id           String         @id @default(cuid())
  actorUserId  String?
  actorType    AuditActorType @default(SYSTEM)
  actorRole    String?        // SUPER_ADMIN / ADMIN / COMPANY_ADMIN 등
  companyId    String?        // 업체 스코프 (COMPANY_ADMIN 행위는 필수)
  actionType   String
  targetType   String?
  targetId     String?
  summary      String
  beforeJson   Json?          // 수정 전 상태
  afterJson    Json?          // 수정 후 상태
  reason       String?        // 변경 사유
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime       @default(now())

  @@index([actorUserId])
  @@index([companyId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([actionType])
  @@map("audit_logs")
}

// ─── Device 관리 ──────────────────────────────────────────

model WorkerDevice {
  id              String    @id @default(cuid())
  workerId        String
  deviceToken     String    @unique
  deviceName      String
  fingerprintHash String?
  platform        String?   // iOS | Android | Web
  browser         String?   // 브라우저/앱 정보
  isPrimary       Boolean   @default(false)
  isActive        Boolean   @default(true)
  // 차단 상태 (isActive=true이더라도 출퇴근 차단 가능)
  isBlocked       Boolean   @default(false)
