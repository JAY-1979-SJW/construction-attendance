// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum AttendanceStatus {
  WORKING           // 출근 후 미퇴근 (당일)
  COMPLETED         // 정상 출퇴근 완료
  MISSING_CHECKOUT  // 퇴근 미기록 (익일 04:00 스케줄러 전환)
  ADJUSTED          // 관리자가 시간 수정한 기록
  ADMIN_MANUAL      // 관리자가 직접 생성한 기록
  EXCEPTION         // 예외 처리 (GPS 실패 등 관리자 승인)
}

enum AttendanceEventType {
  CHECK_IN       // 출근
  MOVE           // 현장 이동 (이동형 근무)
  CHECK_OUT      // 퇴근
  AUTO_CHECK_OUT // 자동 퇴근 처리
}

enum DeviceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OtpPurpose {
  LOGIN
  DEVICE_CHANGE
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum TimeBucket {
  AM
  PM
}

enum PresenceCheckStatus {
  PENDING
  COMPLETED
  MISSED           // legacy, replaced by NO_RESPONSE
  OUT_OF_GEOFENCE
  LOW_ACCURACY     // legacy
  SKIPPED          // legacy
  NO_RESPONSE      // new: expired without response
  REVIEW_REQUIRED  // new: needs admin review
  CANCELED         // new: admin canceled
  MANUALLY_CONFIRMED  // new: admin approved as present
  MANUALLY_REJECTED   // new: admin confirmed absence/violation
}

// ─── Models ──────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  processedDeviceRequests DeviceChangeRequest[] @relation("ProcessedBy")
  auditLogs               AdminAuditLog[]

  @@map("admin_users")
}

model Worker {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  company     String   // 소속 회사 / 협력업체
  jobTitle    String   // 직종 / 역할
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  devices              WorkerDevice[]
  attendanceLogs       AttendanceLog[]
  deviceChangeRequests DeviceChangeRequest[]
  otpVerifications     OtpVerification[]
  attendanceEvents     AttendanceEvent[]
  presenceChecks       PresenceCheck[]

  @@map("workers")
}

model Site {
  id             String   @id @default(cuid())
  name           String
  address        String
  latitude       Float
  longitude      Float
  allowedRadius  Int      @default(100) // meters
  qrToken        String   @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  checkInLogs    AttendanceLog[]   @relation("CheckInSite")
  checkOutLogs   AttendanceLog[]   @relation("CheckOutSite")
  events         AttendanceEvent[]
  presenceChecks PresenceCheck[]

  @@map("sites")
}

model WorkerDevice {
  id          String   @id @default(cuid())
  workerId    String
  deviceToken String   @unique
  deviceName  String   // 기기명 / 표시명
  isPrimary   Boolean  @default(false) // 기본 기기 여부
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_devices")
}

model OtpVerification {
  id          String     @id @default(cuid())
  phone       String
  code        String
  purpose     OtpPurpose
  expiresAt   DateTime
  verifiedAt  DateTime?
  createdAt   DateTime   @default(now())

  // Relations (optional — phone may not yet be registered)
  workerId String?
  worker   Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@map("otp_verifications")
}

model AttendanceLog {
  id              String           @id @default(cuid())
  workerId        String
  // 출근 현장 (체크인 기준)
  siteId          String
  // 퇴근 현장 — 이동형 근무 시 출근 현장과 다를 수 있음 (nullable)
  checkOutSiteId  String?
  workDate        DateTime         @db.Date // 날짜만 저장 (KST 기준)
  checkInAt       DateTime?
  checkOutAt      DateTime?
  checkInLat      Float?
  checkInLng      Float?
  checkOutLat     Float?
  checkOutLng     Float?
  checkInDistance Float?           // 현장까지 거리(m)
  checkOutDistance Float?
  qrToken         String           // 사용된 QR 토큰 스냅샷 (체크인)
  status          AttendanceStatus @default(WORKING)
  exceptionReason String?
  adminNote       String?          // 관리자 메모
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relations
  worker        Worker  @relation(fields: [workerId], references: [id])
  checkInSite   Site    @relation("CheckInSite", fields: [siteId], references: [id])
  checkOutSite  Site?   @relation("CheckOutSite", fields: [checkOutSiteId], references: [id])

  // 이벤트 로그 (이동형 근무)
  events         AttendanceEvent[]
  presenceChecks PresenceCheck[]

  // 같은 근로자, 같은 현장, 같은 날짜는 1건만 허용
  @@unique([workerId, siteId, workDate])
  @@index([workDate])
  @@index([siteId, workDate])
  @@map("attendance_logs")
}

// 출근/이동/퇴근 이벤트 로그 (이동형 근무 지원)
// 상시 GPS 추적 금지 — 버튼 누를 때만 기록
model AttendanceEvent {
  id               String              @id @default(cuid())
  attendanceLogId  String
  workerId         String
  eventType        AttendanceEventType
  siteId           String?             // 연결된 현장 (null 허용: 이동 중)
  occurredAt       DateTime            @default(now())
  latitude         Float?
  longitude        Float?
  accuracy         Float?              // GPS 정확도(m)
  distanceFromSite Float?              // 현장까지 거리(m)
  deviceId         String?             // WorkerDevice.id
  memo             String?

  // Relations
  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  worker        Worker        @relation(fields: [workerId], references: [id])
  site          Site?         @relation(fields: [siteId], references: [id])

  @@index([attendanceLogId])
  @@index([workerId, occurredAt])
  @@map("attendance_events")
}

model DeviceChangeRequest {
  id             String              @id @default(cuid())
  workerId       String
  oldDeviceToken String?
  newDeviceToken String
  newDeviceName  String
  reason         String
  status         DeviceRequestStatus @default(PENDING)
  requestedAt    DateTime            @default(now())
  processedAt    DateTime?
  processedBy    String?             // AdminUser.id

  // Relations
  worker    Worker     @relation(fields: [workerId], references: [id])
  adminUser AdminUser? @relation("ProcessedBy", fields: [processedBy], references: [id])

  @@map("device_change_requests")
}

// ─── 시스템 설정 (싱글톤 — id = "singleton") ─────────────────
model AppSettings {
  id                                String   @id @default("singleton")
  // 플랜
  planType                          String   @default("FREE")   // FREE | PRO
  // 중간 체류 확인 기능
  presenceCheckFeatureAvailable     Boolean  @default(false)    // 플랜상 사용 가능 여부
  presenceCheckEnabled              Boolean  @default(false)    // 관리자 활성화 여부
  presenceCheckAmEnabled            Boolean  @default(true)     // 오전 랜덤 확인
  presenceCheckPmEnabled            Boolean  @default(true)     // 오후 랜덤 확인
  presenceCheckRadiusMeters         Int      @default(30)       // 체류 확인 반경(m)
  presenceCheckResponseLimitMinutes Int      @default(20)       // 응답 제한 시간(분)
  presenceCheckFailureNeedsReview   Boolean  @default(true)     // 실패/미응답 검토 처리
  presenceCheckAmStart              String   @default("09:30")  // 오전 시작 HH:mm
  presenceCheckAmEnd                String   @default("11:30")  // 오전 종료 HH:mm
  presenceCheckPmStart              String   @default("13:30")  // 오후 시작 HH:mm
  presenceCheckPmEnd                String   @default("16:30")  // 오후 종료 HH:mm
  updatedAt                         DateTime @updatedAt

  @@map("app_settings")
}

// ─── 중간 체류 확인 기록 ──────────────────────────────────────
model PresenceCheck {
  id                  String              @id @default(cuid())
  workerId            String
  attendanceLogId     String              // 해당 근무일의 AttendanceLog
  siteId              String              // 생성 시점 기준 현장
  checkDate           String              // 'YYYY-MM-DD' KST 기준 근무일
  timeBucket          TimeBucket          // AM | PM
  scheduledAt         DateTime            // 알림 발송 예정 시각
  expiresAt           DateTime            // 응답 만료 시각
  status              PresenceCheckStatus @default(PENDING)
  respondedAt         DateTime?
  latitude            Float?
  longitude           Float?
  accuracyMeters      Float?
  distanceMeters      Float?
  appliedRadiusMeters Int?                // 판정에 사용된 반경
  needsReview         Boolean             @default(false)
  reviewReason        String?             // MISSED_PRESENCE_CHECK | OUT_OF_GEOFENCE | LOW_ACCURACY
  reviewedBy          String?             // 판정자 (관리자명 스냅샷)
  reviewedAt          DateTime?           // 판정 시각
  adminNote           String?             // 관리자 메모
  reissuedFromId      String?             // 재확인 원본 PC id
  reissueCount        Int                 @default(0) // 재확인 횟수
  closedAt            DateTime?           // 자동 만료/종결 시각
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  worker        Worker        @relation(fields: [workerId], references: [id])
  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  site          Site          @relation(fields: [siteId], references: [id])
  auditLogs     PresenceCheckAuditLog[]

  // 동일 근무일 + 동일 버킷 중복 방지 (attendanceLog 기준)
  @@unique([attendanceLogId, checkDate, timeBucket])
  @@index([workerId, scheduledAt])
  @@index([attendanceLogId])
  @@index([status])
  @@index([scheduledAt])

  @@map("presence_checks")
}

model PresenceCheckAuditLog {
  id                String   @id @default(cuid())
  presenceCheckId   String
  action            String   // CREATED | AUTO_EXPIRED | WORKER_RESPONDED | AUTO_CLASSIFIED_* | ADMIN_CONFIRMED | ADMIN_REJECTED | ADMIN_REISSUED | ADMIN_NOTE_UPDATED | CANCELED
  actorType         String   // SYSTEM | WORKER | ADMIN
  actorId           String?
  actorNameSnapshot String?
  fromStatus        String?
  toStatus          String?
  message           String?
  metadataJson      Json?
  createdAt         DateTime @default(now())

  presenceCheck PresenceCheck @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)

  @@index([presenceCheckId])
  @@index([createdAt])
  @@map("presence_check_audit_logs")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  actionType  String   // e.g. APPROVE_EXCEPTION, REGISTER_WORKER, etc.
  targetType  String?  // e.g. Worker, AttendanceLog, etc.
  targetId    String?
  description String
  createdAt   DateTime @default(now())

  ipAddress   String?

  // Relations
  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}
