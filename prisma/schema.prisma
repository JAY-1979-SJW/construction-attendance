  halfDayRecognitionRule  String   @default("INCLUDE")
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

