}

// ─── 체류 확인 ────────────────────────────────────────────

model PresenceCheck {
  id                  String              @id @default(cuid())
  workerId            String
  attendanceLogId     String
  siteId              String
  checkDate           String
  timeBucket          TimeBucket
  scheduledAt         DateTime
  expiresAt           DateTime
  status              PresenceCheckStatus @default(PENDING)
  respondedAt         DateTime?
  latitude            Float?
  longitude           Float?
  accuracyMeters      Float?
  distanceMeters      Float?
  appliedRadiusMeters Int?
  needsReview         Boolean             @default(false)
  reviewReason        String?
  reviewedBy          String?
  reviewedAt          DateTime?
  adminNote           String?
  reissuedFromId      String?
  reissueCount        Int                 @default(0)
  closedAt            DateTime?
  pushSentAt          DateTime?
  pushFailedAt        DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  worker        Worker        @relation(fields: [workerId], references: [id])
  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  site          Site          @relation(fields: [siteId], references: [id])
  auditLogs     PresenceCheckAuditLog[]

  @@unique([attendanceLogId, checkDate, timeBucket])
  @@index([workerId, scheduledAt])
  @@index([attendanceLogId])
  @@index([status])
  @@index([scheduledAt])

  @@map("presence_checks")
}

model PresenceCheckAuditLog {
  id                String   @id @default(cuid())
  presenceCheckId   String
  action            String
  actorType         String
  actorId           String?
  actorNameSnapshot String?
  fromStatus        String?
  toStatus          String?
  message           String?
  metadataJson      Json?
  createdAt         DateTime @default(now())

  presenceCheck PresenceCheck @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)

  @@index([presenceCheckId])
  @@index([createdAt])
  @@map("presence_check_audit_logs")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  actionType  String
  targetType  String?
  targetId    String?
  description String
  createdAt   DateTime @default(now())
  ipAddress   String?

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ─── 노무 관리 Models ─────────────────────────────────────

model WorkerContract {
  id                       String       @id @default(cuid())
  workerId                 String
  siteId                   String?
  contractType             ContractType @default(DAILY)
  startDate                String       // 'YYYY-MM-DD'
  endDate                  String?
  dailyWage                Int          @default(0)
  monthlySalary            Int?
  hourlyRate               Int?
  overtimeRate             Decimal?     @db.Decimal(4, 2)
  nightRate                Decimal?     @db.Decimal(4, 2)
  holidayRate              Decimal?     @db.Decimal(4, 2)
  halfDayRule              String       @default("HALF")
  taxRuleType              String       @default("DAILY_WAGE")
  insuranceRuleType        String       @default("DEFAULT")
  retirementMutualRuleType String       @default("DEFAULT")
  notes                    String?
  isActive                 Boolean      @default(true)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site   Site?  @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([workerId])
  @@index([siteId])
  @@index([startDate])
  @@map("worker_contracts")
}

model AttendanceDay {
  id                      String                      @id @default(cuid())
  workerId                String
  siteId                  String
  workDate                String   // 'YYYY-MM-DD'
  firstCheckInAt          DateTime?
  lastCheckOutAt          DateTime?
  workedMinutesRaw        Int?
  presenceStatus          AttendanceDayPresenceStatus @default(NORMAL)
  presenceReviewResult    String?
  attendanceSourceSummary Json?
  hasMoveBetweenSites     Boolean  @default(false)
  manualAdjustedYn        Boolean  @default(false)
  manualAdjustedReason    String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Restrict)
  workConfirmations MonthlyWorkConfirmation[]

  @@unique([workerId, siteId, workDate])
  @@index([workerId, workDate])
  @@index([siteId, workDate])
  @@map("attendance_days")
}

model MonthlyWorkConfirmation {
  id                              String                 @id @default(cuid())
  workerId                        String
  siteId                          String
  workDate                        String   // 'YYYY-MM-DD'
  monthKey                        String   // 'YYYY-MM'
  attendanceDayId                 String?
  confirmationStatus              WorkConfirmationStatus @default(DRAFT)
  confirmedWorkType               ConfirmedWorkType?
  confirmedWorkUnits              Decimal  @default(0) @db.Decimal(4, 2)
  confirmedWorkMinutes            Int      @default(0)
  confirmedBaseAmount             Int      @default(0)
  confirmedAllowanceAmount        Int      @default(0)
  confirmedTotalAmount            Int      @default(0)
  incomeTypeSnapshot              String?
  employmentTypeSnapshot          String?
  retirementMutualTargetSnapshot  Boolean?
  insuranceReviewSnapshotJson     Json?
  confirmedBy                     String?
  confirmedAt                     DateTime?
  notes                           String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  worker        Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site          Site           @relation(fields: [siteId], references: [id], onDelete: Restrict)
  attendanceDay AttendanceDay? @relation(fields: [attendanceDayId], references: [id], onDelete: SetNull)
  retirementRecords RetirementMutualDailyRecord[]

  @@unique([workerId, siteId, workDate])
  @@index([workerId, monthKey])
  @@index([siteId, monthKey])
  @@index([monthKey])
  @@map("monthly_work_confirmations")
}

model InsuranceEligibilitySnapshot {
  id                           String  @id @default(cuid())
  workerId                     String
  monthKey                     String  // 'YYYY-MM'
  totalWorkDays                Int     @default(0)
  totalConfirmedAmount         Int     @default(0)
