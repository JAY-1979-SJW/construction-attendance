// ─── 관리자 노동법 FAQ ──────────────────────────────────────────────────────

model LaborFaq {
  id                   String   @id @default(cuid())
  category             String   // CONTRACT_TYPE | DAILY_WORKER | REGULAR | FIXED_TERM | REPEATED_CONTRACT | OUTSOURCING | DOCUMENT_SELECTION | LEGAL_WARNING
  question             String
  questionAliases      Json     @default("[]")  // string[]
  shortAnswer          String
  fullAnswer           String   @db.Text
  appRule              String?  // 앱 처리 기준
  caution              String?  // 주의사항
  sourceOrg            String   // 출처 기관
  sourceTitle          String   // 출처 문서명
  sourceUrl            String?  // 출처 URL
  effectiveDate        String   // 'YYYY-MM-DD'
  lastReviewedAt       DateTime?
  relatedContractTypes Json     @default("[]")  // string[] ('DAILY_EMPLOYMENT', 'REGULAR_EMPLOYMENT', 'FIXED_TERM_EMPLOYMENT', ...)
  triggerConditions    Json     @default("[]")  // TriggerCondition[]
  priority             Int      @default(50)    // 1~100, 높을수록 우선 노출
  status               String   @default("APPROVED") // DRAFT | REVIEWED | APPROVED | INACTIVE
  isActive             Boolean  @default(true)
  viewCount            Int      @default(0)
  createdBy            String?
  updatedBy            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  changeLogs LaborFaqChangeLog[]

  @@index([category])
  @@index([status, isActive])
  @@index([priority(sort: Desc)])
  @@map("labor_faqs")
}

model LaborFaqChangeLog {
  id             String   @id @default(cuid())
  faqId          String
  changedBy      String
  changedAt      DateTime @default(now())
  changeType     String   // CREATE | UPDATE | ACTIVATE | DEACTIVATE | STATUS_CHANGE
  beforeSnapshot Json?
  afterSnapshot  Json?
  note           String?

  faq LaborFaq @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@index([faqId])
  @@index([changedAt])
  @@map("labor_faq_change_logs")
}

// ─── 분쟁방어 패널 ──────────────────────────────────────────────────────────

model DisputeCase {
  id              String        @id @default(cuid())
  workerId        String
  companyId       String
  siteId          String?
  disputeType     DisputeType
  status          DisputeStatus @default(OPEN)
  title           String
  summary         String?       @db.Text
  openedAt        DateTime      @default(now())
  resolvedAt      DateTime?
  closedAt        DateTime?
  openedBy        String        // admin user id
  defenseScore    Int?          // 0-100, evidence completeness score
  metadataJson    Json?         // dispute-type specific fields

  worker   Worker  @relation(fields: [workerId], references: [id])
  company  Company @relation(fields: [companyId], references: [id])

  notes     DisputeCaseNote[]
  snapshots DefensePanelSnapshot[]

  @@index([workerId])
  @@index([companyId])
  @@index([status])
  @@index([disputeType])
  @@map("dispute_cases")
}

model DisputeCaseNote {
  id          String   @id @default(cuid())
  caseId      String
  authorId    String   // admin user id
  content     String   @db.Text
  isInternal  Boolean  @default(true) // true = 관리자 내부 메모, false = 처리 결과
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  case DisputeCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([createdAt])
  @@map("dispute_case_notes")
}

model DefensePanelSnapshot {
  id          String      @id @default(cuid())
  caseId      String?
  workerId    String
  companyId   String
  takenBy     String      // admin user id
  snapshotJson Json       // full panel state at time of export
  exportedAt  DateTime    @default(now())
  reason      String?     // why snapshot was taken

  case    DisputeCase? @relation(fields: [caseId], references: [id])
  worker  Worker       @relation(fields: [workerId], references: [id])
  company Company      @relation(fields: [companyId], references: [id])

  @@index([workerId])
  @@index([caseId])
  @@index([exportedAt])
  @@map("defense_panel_snapshots")
}

model DocumentDeliveryLog {
  id             String                  @id @default(cuid())
  workerId       String
  companyId      String
  documentType   String                  // matches DocumentType enum values
  contractId     String?
  deliveryMethod DocumentDeliveryMethod
  status         DocumentDeliveryStatus
  deliveredAt    DateTime?
  deliveredBy    String?                 // admin user id if manually recorded
  signatureJson  Json?                   // signature data / confirmation blob
  metadataJson   Json?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  worker  Worker  @relation(fields: [workerId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([workerId])
  @@index([companyId])
  @@index([documentType])
  @@index([status])
  @@map("document_delivery_logs")
}

model AttendanceAdjustmentLog {
  id                  String   @id @default(cuid())
  attendanceRecordId  String   // WorkAttendance id
  workerId            String
  companyId           String
  adjustedBy          String   // admin user id
  field               String   // 'checkInAt' | 'checkOutAt' | 'workedMinutes' | 'status'
  beforeValue         String?
  afterValue          String?
  reason              String   @db.Text
  approvedBy          String?  // second approver if required
  createdAt           DateTime @default(now())

  worker  Worker  @relation(fields: [workerId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([attendanceRecordId])
  @@index([workerId])
  @@index([adjustedBy])
  @@index([createdAt])
  @@map("attendance_adjustment_logs")
}

// ─── 근로자 제한형 요청 ──────────────────────────────────────────────────────

model WorkerRequest {
  id           String                @id @default(cuid())
  workerId     String
  companyId    String?
  siteId       String?
  category     WorkerRequestCategory
  status       WorkerRequestStatus   @default(PENDING)
  content      String                @db.Text  // max 200자 enforced at app level
  adminMemo    String?               @db.Text  // admin-only response/note
  reviewedBy   String?               // admin user id
  reviewedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  worker  Worker   @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
  @@map("worker_requests")
}

// ─── 관리행위 (경고·소명·통지·종료) Enums ─────────────────────────────────────

enum WarningLevel {
  VERBAL   // 구두 경고
  WRITTEN  // 서면 경고
  FINAL    // 최종 경고 (종료 전)
}

enum ExplanationStatus {
  PENDING    // 소명 요청됨
  SUBMITTED  // 소명 제출됨
  REVIEWED   // 검토 완료
  CLOSED     // 종결
}

enum NoticeType {
  CONTRACT_END  // 계약만료 통지
  TERMINATION   // 종료/해고 통지
  SUSPENSION    // 업무 정지 통지
  WARNING       // 경고 통지
  OTHER         // 기타
}

enum TerminationReason {
  CONTRACT_EXPIRY      // 계약기간 만료
  VOLUNTARY_RESIGN     // 자진 퇴사
  MUTUAL_AGREEMENT     // 합의 종료
  DISCIPLINARY         // 징계성 종료
  ABSENCE              // 무단결근 후 종료
  PERFORMANCE          // 업무 부적합
  SITE_CLOSURE         // 현장 종료
  REPEATED_ABSENCE     // 반복 미출근
  INSTRUCTION_REFUSAL  // 지시 불이행
  OTHER                // 기타
}

enum TerminationReviewStatus {
  DRAFT       // 작성 중
  IN_PROGRESS // 점검 진행 중
  CONFIRMED   // 종료 확정
  CANCELLED   // 취소됨
}

// ─── 경고 기록 ────────────────────────────────────────────────────────────────

model WorkerWarningRecord {
  id            String       @id @default(cuid())
  workerId      String
  companyId     String
  issuedBy      String       // admin user id
  warningLevel  WarningLevel
  reason        String       @db.Text
  detailMemo    String?      @db.Text
  workerAcknowledged Boolean @default(false)
  acknowledgedAt DateTime?
  relatedAttendanceDate String?  // 'YYYY-MM-DD' 관련 출근일
  documentPath  String?      // 첨부 경고장 파일 경로
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  worker  Worker  @relation(fields: [workerId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([workerId])
  @@index([companyId])
  @@index([createdAt])
  @@map("worker_warning_records")
}

// ─── 소명 요청 ────────────────────────────────────────────────────────────────

model WorkerExplanationRequest {
  id           String            @id @default(cuid())
  workerId     String
  companyId    String
  requestedBy  String            // admin user id
  status       ExplanationStatus @default(PENDING)
  subject      String            // 소명 요청 제목
  reason       String            @db.Text  // 소명 요청 사유
  deadline     DateTime?         // 소명 제출 기한
  workerReply  String?           @db.Text  // 근로자 답변
  repliedAt    DateTime?
  reviewNote   String?           @db.Text  // 관리자 검토 결과
  reviewedBy   String?
  reviewedAt   DateTime?
  relatedWarningId String?       // 관련 경고 ID
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  worker  Worker  @relation(fields: [workerId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([workerId])
  @@index([companyId])
  @@index([status])
  @@map("worker_explanation_requests")
}

// ─── 통지 기록 ────────────────────────────────────────────────────────────────

model WorkerNoticeRecord {
  id              String     @id @default(cuid())
  workerId        String
  companyId       String
  noticeType      NoticeType
  issuedBy        String     // admin user id
  title           String
  content         String     @db.Text
  effectiveDate   String?    // 'YYYY-MM-DD'
  deliveredAt     DateTime?
  deliveryMethod  String?    // APP | EMAIL | PAPER | KAKAO
  workerConfirmed Boolean    @default(false)
  confirmedAt     DateTime?
  documentPath    String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  worker  Worker  @relation(fields: [workerId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@index([workerId])
  @@index([companyId])
  @@index([noticeType])
  @@map("worker_notice_records")
}

// ─── 종료 처리 검토 ───────────────────────────────────────────────────────────

model WorkerTerminationReview {
  id                    String                  @id @default(cuid())
  workerId              String
  companyId             String
  initiatedBy           String                  // admin user id
  status                TerminationReviewStatus @default(DRAFT)

  // 6-4. 기본정보
  terminationReason     TerminationReason?
  terminationDate       String?                 // 'YYYY-MM-DD'
  reasonCategory        String?
  detailReason          String?                 @db.Text

  // 6-5. 자동점검 결과 (JSON: { item: string, passed: boolean, severity: 'OK'|'WARN'|'DANGER'|'CRITICAL' }[])
  autoCheckResultJson   Json?

  // 6-7. 관리자 최종확인 체크박스
  confirmCheckedReason        Boolean @default(false)  // 종료 사유 확인
  confirmCheckedDocuments     Boolean @default(false)  // 관련 문서 확인
  confirmCheckedDelivery      Boolean @default(false)  // 교부/통지 상태 확인
  confirmCheckedWage          Boolean @default(false)  // 미정산 여부 확인
  confirmCheckedDispute       Boolean @default(false)  // 분쟁 가능성 검토

  confirmedBy   String?
  confirmedAt   DateTime?
  cancelledBy   String?
  cancelledAt   DateTime?
  cancelReason  String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  worker   Worker   @relation(fields: [workerId], references: [id])
  company  Company  @relation(fields: [companyId], references: [id])
  snapshot WorkerTerminationSnapshot?

  @@index([workerId])
  @@index([companyId])
  @@index([status])
  @@map("worker_termination_reviews")
}

// ─── 종료 스냅샷 ─────────────────────────────────────────────────────────────

model WorkerTerminationSnapshot {
  id         String   @id @default(cuid())
  reviewId   String   @unique
  workerId   String
  companyId  String
  takenBy    String   // admin user id
  takenAt    DateTime @default(now())

  // 6-8. 저장 항목 (전체 상태 스냅샷)
  workerJson          Json  // 근로자 기본정보
  contractsJson       Json  // 계약 이력
  attendanceSummaryJson Json // 출퇴근 요약
  documentsJson       Json  // 문서 목록
  warningsJson        Json  // 경고 이력
  explanationsJson    Json  // 소명 이력
  noticesJson         Json  // 통지 이력
  checklistJson       Json  // 체크리스트 결과

  review  WorkerTerminationReview @relation(fields: [reviewId], references: [id])
  worker  Worker                  @relation(fields: [workerId], references: [id])
  company Company                 @relation(fields: [companyId], references: [id])

  @@index([workerId])
  @@index([takenAt])
  @@map("worker_termination_snapshots")
}

// ─── 현장 운영 기록 모델 (v3) ─────────────────────────────

// 현장 공지
// 일반/안전/일정/검측/자재반입/출입통제/긴급 공지를 통합 관리
// visibilityScope 로 근로자/관리자 노출 범위를 분리함
model SiteNotice {
  id                String             @id @default(cuid())
  siteId            String
  title             String
  content           String             @db.Text
  noticeType        SiteNoticeType     @default(GENERAL_NOTICE)
  visibilityScope   SiteVisibilityScope @default(ALL_WORKERS)
  targetTeamLabel   String?            // SPECIFIC_TEAM_ONLY 일 때 팀 레이블
  startDate         DateTime           @db.Date
  endDate           DateTime?          @db.Date
  isTodayHighlight  Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdById       String             // AdminUser.id (FK 미강제, soft ref)
  updatedById       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, isActive])
  @@index([siteId, startDate, endDate])
  @@map("site_notices")
}

// 현장 당일 일정
// 그날 예정된 TBM / 검측 / 자재반입 / 안전점검 / 회의 / 출입통제 이벤트를 관리
// 공지(사전 전달)와 달리 실행 예정 이벤트 중심
model SiteDailySchedule {
  id                  String                  @id @default(cuid())
  siteId              String
  scheduleDate        DateTime                @db.Date
  scheduleType        SiteDailyScheduleType   @default(OTHER)
  title               String
  description         String?                 @db.Text
  plannedStartAt      DateTime?
  plannedEndAt        DateTime?
  location            String?
  responsiblePersonId String?                 // AdminUser.id (soft ref)
  targetTeamLabel     String?
  visibilityScope     SiteVisibilityScope     @default(ALL_WORKERS)
  status              SiteDailyScheduleStatus @default(PLANNED)
  createdById         String
  updatedById         String?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, scheduleDate])
  @@index([siteId, scheduleType])
  @@map("site_daily_schedules")
}

// ─── 작업지시문 ─────────────────────────────────────────────────────────────
// 관리자가 근로자에게 앱을 통해 작업지시를 내리고, 근로자가 확인/수신하는 문서
model WorkOrder {
  id              String          @id @default(cuid())
  siteId          String
  orderDate       DateTime        @db.Date
  title           String
  content         String          @db.Text
  priority        WorkOrderPriority @default(NORMAL)
  issuedById      String          // AdminUser.id
  targetScope     WorkOrderScope  @default(ALL_SITE)
  targetWorkerId  String?         // SPECIFIC_WORKER일 때
  targetTradeType String?         // SPECIFIC_TRADE일 때
  attachments     String[]        @default([])
  status          WorkOrderStatus @default(ISSUED)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  worker  Worker? @relation(fields: [targetWorkerId], references: [id], onDelete: SetNull)
  acknowledgements WorkOrderAck[]

  @@index([siteId, orderDate])
  @@index([status])
  @@map("work_orders")
}

// 근로자 수신 확인
model WorkOrderAck {
  id          String   @id @default(cuid())
  workOrderId String
  workerId    String
  readAt      DateTime @default(now())
  confirmedAt DateTime?  // 작업지시 이해/수락 확인

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, workerId])
  @@map("work_order_acks")
}

enum WorkOrderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum WorkOrderScope {
  ALL_SITE         // 현장 전체
  SPECIFIC_TRADE   // 특정 공종
  SPECIFIC_WORKER  // 특정 근로자
}

enum WorkOrderStatus {
  DRAFT
  ISSUED      // 발행됨
  COMPLETED   // 완료 처리
  CANCELLED
}

// 작업일보 본체
// 하루 현장 운영 결과를 요약하는 문서
// 출근자명 나열 문서 아님 — 명수 중심 요약 허브
// memoInternal 은 관리자 전용 (근로자 API 응답에서 제외 필수)
model SiteWorkLog {
  id                    String            @id @default(cuid())
  siteId                String
  workDate              DateTime          @db.Date
  status                SiteWorkLogStatus @default(DRAFT)
  writtenById           String            // AdminUser.id
  reviewedById          String?
  approvedById          String?
  summaryText           String?           @db.Text  // 당일 운영 요약
  majorWorkText         String?           @db.Text  // 팀별 주요 작업 내용
  issueText             String?           @db.Text  // 특이사항
  // ── TBM 요약 ───────────────────────────────────────────────────────────────
  tbmSummaryText        String?           @db.Text  // TBM 결과 요약 (전달사항 포함)
  // ── 안전 요약 ──────────────────────────────────────────────────────────────
  safetySummaryText     String?           @db.Text  // 안전 전달사항 요약
  safetyHazardText      String?           @db.Text  // 위험요소
  safetyActionText      String?           @db.Text  // 조치사항 (보호구·통제·시정 등)
  safetyIncidentOccurred  Boolean         @default(false)  // 사고/아차사고 발생 여부
  safetyCorrectionNeeded  Boolean         @default(false)  // 시정 조치 필요 여부
  safetyCorrectionDone    Boolean         @default(false)  // 시정 완료 여부
  // ── 검측·자재 (2차에서 확장) ────────────────────────────────────────────
  inspectionSummaryText String?           @db.Text  // 검측 요약
  materialSummaryText   String?           @db.Text  // 자재 반입 요약
  memoInternal          String?           @db.Text  // 관리자 전용 메모 — 공개 API 노출 금지
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  site    Site                @relation(fields: [siteId], references: [id], onDelete: Cascade)
  summary SiteWorkLogSummary?

  @@unique([siteId, workDate])
  @@index([siteId, workDate])
  @@index([status])
  @@map("site_work_logs")
}

// 작업일보 요약 집계
// 빠른 조회·출력용 집계 데이터
// SiteWorkLog 와 1:1 연결, 또는 독립 집계로도 사용 가능
model SiteWorkLogSummary {
  id                          String   @id @default(cuid())
  siteId                      String
  workDate                    DateTime @db.Date
  workLogId                   String?  @unique  // SiteWorkLog 연결 (optional)
  totalPresentCount           Int      @default(0)
  directWorkerCount           Int      @default(0)
  subcontractWorkerCount      Int      @default(0)
  teamCount                   Int      @default(0)
  tbmConducted                Boolean  @default(false)
  tbmAttendedCount            Int      @default(0)
  tbmAbsentCount              Int      @default(0)
  safetyIssueCount            Int      @default(0)
  inspectionPlannedCount      Int      @default(0)
  inspectionDoneCount         Int      @default(0)
  materialDeliveryPlannedCount Int     @default(0)
  materialDeliveryDoneCount   Int      @default(0)
  issueCount                  Int      @default(0)
  photoCount                  Int      @default(0)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  site    Site         @relation(fields: [siteId], references: [id], onDelete: Cascade)
  workLog SiteWorkLog? @relation(fields: [workLogId], references: [id])

  @@unique([siteId, workDate])
  @@index([siteId, workDate])
  @@map("site_work_log_summaries")
}

// 당일 인원별 상태
// 출근자명 전체는 이 모델에서만 조회 (작업일보 본문 직접 삽입 금지)
// attendance_logs 기반으로 생성/동기화 가능하도록 attendanceLogId 참조 보유
model SiteDailyWorkerStatus {
  id                  String                     @id @default(cuid())
  siteId              String
  workDate            DateTime                   @db.Date
  workerId            String
  companyId           String?
  teamLabel           String?                    // 팀/반 레이블 (tradeType 기반)
  attendanceLogId     String?                    // AttendanceLog 연결 (soft ref)
  attendanceStatus    SiteWorkerAttendanceStatus @default(UNKNOWN)
  checkInAt           DateTime?
  checkOutAt          DateTime?
  tbmStatus           SiteTbmParticipationStatus @default(UNKNOWN)
  tbmCheckedAt        DateTime?
  safetyCheckStatus   SiteSafetyCheckStatus      @default(UNKNOWN)
  safetyCheckedAt     DateTime?
  workAssignedStatus  SiteWorkAssignedStatus     @default(UNKNOWN)
  remarks             String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  worker Worker @relation(fields: [workerId], references: [id])

  @@unique([siteId, workDate, workerId])
  @@index([siteId, workDate])
  @@index([workerId])
  @@map("site_daily_worker_statuses")
}

// TBM 기록
// TBM 실시 내용과 참석 집계를 보관
// 1차: count 기반, 2차에서 attendee 개별 relation 확장 가능
model SiteTbmRecord {
  id             String    @id @default(cuid())
  siteId         String
  workDate       DateTime  @db.Date
  title          String
  content        String?   @db.Text
  conductedAt    DateTime?
  conductorId    String?   // AdminUser.id (soft ref)
  attendeeCount  Int       @default(0)
  absentCount    Int       @default(0)
  notes          String?
  createdById    String
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, workDate])
  @@map("site_tbm_records")
}

// ─── 범용 계약내역서 관리 ──────────────────────────────────

enum EstimateParseStatus {
  UPLOADED
  PARSING
  PARSED
  REVIEW_REQUIRED
  FAILED
}

enum EstimateDocumentType {
  ESTIMATE            // 내역서
  CHANGE_ESTIMATE     // 설계변경 내역서
  UNIT_PRICE_SOURCE   // 일위대가
  PRICE_TABLE         // 단가표
  OTHER               // 기타
}

enum SheetType {
  SUMMARY             // 총괄표, 원가계산
  TRADE_SUMMARY       // 공종별 집계표
  DETAIL_BILL         // 내역서 (상세)
  UNIT_PRICE          // 일위대가
  PRICE_TABLE         // 단가표, 자재단가
  REFERENCE           // 참고자료, 개요
  UNKNOWN             // 미분류
}

enum NormalizationSource {
  DICTIONARY
  SYNONYM
  MANUAL
  UNMAPPED
}

enum AggregationStatus {
  DRAFT       // 자동 생성 직후
  REVIEWED    // 관리자 검토 완료
  CONFIRMED   // 최종 확정
}

// 계약내역서 문서
model EstimateDocument {
  id            String                @id @default(cuid())
  siteId        String?
  fileName      String
  filePath      String
  fileSize      Int?
  documentType  EstimateDocumentType  @default(ESTIMATE)
  uploadedBy    String
  uploadedAt    DateTime              @default(now())
  parseStatus   EstimateParseStatus   @default(UPLOADED)
  parseVersion  Int                   @default(0)
  sheetCount    Int                   @default(0)
  errorMessage  String?               @db.Text
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  site    Site?                   @relation(fields: [siteId], references: [id], onDelete: SetNull)
  sheets  EstimateDocumentSheet[]
  billRows EstimateBillRow[]
  aggregateRows MaterialAggregateRow[]
  aggregationRuns EstimateAggregationRun[]

  @@index([siteId])
  @@index([parseStatus])
  @@map("estimate_documents")
}

// 워크북 내 시트 정보
model EstimateDocumentSheet {
  id                String      @id @default(cuid())
  documentId        String
  sheetName         String
  sheetIndex        Int
  sheetType         SheetType   @default(UNKNOWN)
  discipline        String?     // 자유 분류값 예: "소방전기", "기계설비", "건축" 등
  maxRows           Int         @default(0)
  maxCols           Int         @default(0)
  mergeRangesJson   String?     @db.Text   // [{s:{r,c}, e:{r,c}}] 원본 병합 범위
  rawDataJson       String?     @db.Text   // 원문 셀 데이터 배열 (rowspan/colspan 렌더링용)
  isHidden          Boolean     @default(false)
  needsReview       Boolean     @default(false)
  headerRowIndex    Int?
  dataStartRowIndex Int?
  parseStatus       EstimateParseStatus @default(UPLOADED)
  rowCount          Int         @default(0)
  createdAt         DateTime    @default(now())

  document  EstimateDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  billRows  EstimateBillRow[]

  @@index([documentId])
  @@map("estimate_document_sheets")
}

// 원본 항목 행 (범용)
model EstimateBillRow {
  id             String    @id @default(cuid())
  documentId     String
  sheetId        String
  sheetName      String
  discipline     String?   // 자유 분류값
  rowNo          Int
  sectionName    String?
  subsectionName String?
  rawItemName    String?
  rawSpec        String?
  rawUnit        String?
  rawQuantity    String?
  rawUnitPrice   String?
  rawAmount      String?
  rawNote        String?
  quantity       Decimal?  @db.Decimal(18, 4)
  unitPrice      Decimal?  @db.Decimal(18, 2)
  amount         Decimal?  @db.Decimal(18, 2)
  isSummaryRow   Boolean   @default(false)
  rowType        String?   // "DATA" | "SECTION" | "SUBSECTION" | "SUMMARY" | "TITLE"
  parseConfidence Float?
  headerPathJson    String?   @db.Text
  groupContextJson  String?   @db.Text
  rawRowJson        String?   @db.Text
  aggregateCandidate Boolean  @default(false)
  reviewRequired    Boolean   @default(false)
  reviewReasonsJson String?
  sourceCellRange   String?
  // ── Phase 3: 수동 보정 필드 ──────────────────────────────
  manualItemName          String?
  manualSpec              String?
  manualUnit              String?
  manualQuantity          Decimal?  @db.Decimal(18, 4)
  manualGroupKey          String?
  excludeFromAggregation  Boolean   @default(false)
  overrideReason          String?
  overriddenBy            String?
  overriddenAt            DateTime?
  createdAt      DateTime  @default(now())

  document    EstimateDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sheet       EstimateDocumentSheet  @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  normalized  EstimateBillRowNormalized?
  overrides   EstimateRowOverride[]

  @@index([documentId])
  @@index([sheetId])
  @@index([manualGroupKey])
  @@index([excludeFromAggregation])
  @@map("estimate_bill_rows")
}

// 정규화 결과
model EstimateBillRowNormalized {
  id                    String              @id @default(cuid())
  billRowId             String              @unique
  normalizedItemName    String?
  normalizedSpec        String?
  normalizedUnit        String?
  itemCategory          String?
  itemCode              String?
  normalizationSource   NormalizationSource @default(UNMAPPED)
  normalizationConfidence Float?
  groupKey              String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  billRow EstimateBillRow @relation(fields: [billRowId], references: [id], onDelete: Cascade)

  @@index([groupKey])
  @@index([itemCode])
  @@map("estimate_bill_row_normalized")
}

// 집계 결과
model MaterialAggregateRow {
  id                    String    @id @default(cuid())
  documentId            String
  discipline            String?
  itemCode              String?
  normalizedItemName    String
  normalizedSpec        String?
  normalizedUnit        String?
  itemCategory          String?
  totalQuantity         Decimal   @db.Decimal(18, 4)
  totalAmount           Decimal?  @db.Decimal(18, 2)
  sourceRowCount        Int       @default(0)
  sourceRowIdsJson      String?   @db.Text
  unitPriceInconsistent Boolean   @default(false)
  reviewRequired    Boolean   @default(false)
  groupKey              String
  // ── Phase 3: 상태·확정·재집계 필드 ───────────────────────
  aggregationStatus     AggregationStatus @default(DRAFT)
  manualOverrideUsed    Boolean   @default(false)
  confirmedBy           String?
  confirmedAt           DateTime?
  regeneratedAt         DateTime?
  createdAt             DateTime  @default(now())

  document EstimateDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([discipline])
  @@index([groupKey])
  @@index([aggregationStatus])
  @@map("material_aggregate_rows")
}

// ── Phase 3: 행 보정 이력 ─────────────────────────────────
model EstimateRowOverride {
  id          String    @id @default(cuid())
  rowId       String
  fieldName   String    // manualItemName | manualSpec | manualUnit | manualQuantity | manualGroupKey | excludeFromAggregation
  beforeValue String?   @db.Text
  afterValue  String?   @db.Text
  reason      String?
  changedBy   String
  changedAt   DateTime  @default(now())

  row EstimateBillRow @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@index([rowId])
  @@index([changedAt])
  @@map("estimate_row_overrides")
}

// ── Phase 3: 집계 실행 이력 ───────────────────────────────
model EstimateAggregationRun {
  id                   String    @id @default(cuid())
  documentId           String
  runType              String    // AUTO | MANUAL_REBUILD
  rowCount             Int       @default(0)
  aggregateCount       Int       @default(0)
  reviewRequiredCount  Int       @default(0)
  startedAt            DateTime  @default(now())
  completedAt          DateTime?

  document EstimateDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("estimate_aggregation_runs")
}

// ─── 나라장터 자원분류 마스터 ────────────────────────────────────────────────
// getNetRsceinfoList API 전체 수집 데이터 (E경비/L노무/M재료, 약 58,589건)
// 수집 스크립트: scripts/collect_nara_resources.py
model NaraResource {
  id              Int      @id @default(autoincrement())
  rsceTyExtrnlCd  String?  // 자원유형 코드 (E/L/M)
  lvlRsceClsfcNm1 String?  // 대분류명
  lvlRsceClsfcNm2 String?  // 중분류명
  netRsceCd       String?  // 자원코드
  rsceNm          String?  // 자원명
  rsceSpecNm      String?  // 규격명
  unit            String?  // 단위
  lbrcst          Decimal? // 단가 (현재 0)
  collectedAt     DateTime @default(now())

  @@index([rsceTyExtrnlCd])
  @@index([lvlRsceClsfcNm1])
  @@index([rsceNm])
  @@map("nara_resources")
}

// ─── 자재청구 Enums ───────────────────────────────────────────────────────────

enum MaterialRequestStatus {
  DRAFT      // 작성중
  SUBMITTED  // 제출됨
  REVIEWED   // 검토됨
  APPROVED   // 승인됨
  REJECTED   // 반려됨
  CANCELLED  // 취소됨
}

enum MaterialRequestActorType {
  ADMIN
  SYSTEM
  WORKER
}

// 자재 마스터
model MaterialMaster {
  id                      String    @id @default(cuid())
  discipline              String?
  itemCode                String    @unique
  standardItemName        String
  standardSpec            String?
  standardUnit            String?
  itemCategory            String?
  synonymsJson            String?   @db.Text
  specAliasesJson         String?   @db.Text
  approvalRequired        Boolean   @default(false)
  active                  Boolean   @default(true)
  // 자재청구 분류 필드
  disciplineCode          String?   // E/T/M/A/C/ETC
  subDisciplineCode       String?   // FIRE_MECH/FIRE_ELEC/LANDSCAPE 등
  searchKeywords          String?   @db.Text
  isRequestable           Boolean   @default(true)
  g2bSourceId             String?   // nara_material_catalog 연결 ID
  classificationUpdatedAt DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  requestItems MaterialRequestItem[]

  @@index([discipline])
  @@index([itemCategory])
  @@index([disciplineCode])
  @@index([isRequestable])
  @@map("material_master")
}

// ─── 자재청구서 ───────────────────────────────────────────────────────────────

model MaterialRequest {
  id           String                 @id @default(cuid())
  requestNo    String                 @unique // MR-YYYYMMDD-NNNN
  siteId       String?
  requestedBy        String                   // Admin userId (WORKER인 경우 'WORKER' 고정값)
  workerRequesterId  String?                  // actorType=WORKER일 때 Worker.id
  actorType          MaterialRequestActorType @default(ADMIN)
  status             MaterialRequestStatus    @default(DRAFT)
  title        String
  notes        String?                @db.Text
  deliveryRequestedAt DateTime?
  submittedAt  DateTime?
  reviewedAt   DateTime?
  reviewedBy   String?
  approvedAt   DateTime?
  approvedBy   String?
  rejectedAt   DateTime?
  rejectedBy   String?
  rejectReason String?                @db.Text
  cancelledAt  DateTime?
  cancelledBy  String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  site            Site?                        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  workerRequester Worker?                      @relation("WorkerMaterialRequests", fields: [workerRequesterId], references: [id], onDelete: SetNull)
  items           MaterialRequestItem[]
  history         MaterialRequestStatusHistory[]
  purchaseOrders  PurchaseOrder[]

  @@index([siteId])
  @@index([status])
  @@index([requestedBy])
  @@index([workerRequesterId])
  @@map("material_requests")
}

model MaterialRequestItem {
  id               String   @id @default(cuid())
  requestId        String
  materialMasterId String?
  // 청구 시점 스냅샷
  itemCode         String
  itemName         String
  spec             String?
  unit             String?
  disciplineCode   String?
  subDisciplineCode String?
  // 수량/금액
  requestedQty     Decimal  @db.Decimal(15, 4)
  approvedQty      Decimal? @db.Decimal(15, 4)
  unitPrice        Decimal? @db.Decimal(15, 2)
  isUrgent         Boolean  @default(false)
  allowSubstitute  Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  request            MaterialRequest    @relation(fields: [requestId], references: [id], onDelete: Cascade)
  materialMaster     MaterialMaster?   @relation(fields: [materialMasterId], references: [id], onDelete: SetNull)
  purchaseOrderItems PurchaseOrderItem[]

  @@index([requestId])
  @@index([materialMasterId])
  @@map("material_request_items")
}

model MaterialRequestStatusHistory {
  id         String                  @id @default(cuid())
  requestId  String
  fromStatus MaterialRequestStatus?
  toStatus   MaterialRequestStatus
  actorId    String?
  actorType  MaterialRequestActorType @default(ADMIN)
  reason     String?                 @db.Text
  createdAt  DateTime                @default(now())

  request MaterialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@map("material_request_status_history")
}

// ─── 발주 ─────────────────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT               // 작성중
  ISSUED              // 발행됨
  PARTIALLY_RECEIVED  // 부분입고
  RECEIVED            // 전량입고
  CANCELLED           // 취소됨
}

model PurchaseOrder {
  id                    String              @id @default(cuid())
  orderNo               String              @unique  // PO-YYYYMMDD-NNNN
  materialRequestId     String
  siteId                String?
  vendorId              String?
  status                PurchaseOrderStatus @default(DRAFT)
  orderedByUserId       String
  orderedAt             DateTime?
  issuedAt              DateTime?
  cancelledAt           DateTime?
  deliveryRequestedDate DateTime?           @db.Date
  memo                  String?             @db.Text
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  materialRequest MaterialRequest              @relation(fields: [materialRequestId], references: [id], onDelete: Restrict)
  site            Site?                        @relation(fields: [siteId], references: [id], onDelete: SetNull)
  items           PurchaseOrderItem[]
  history         PurchaseOrderStatusHistory[]
  goodsReceipts   GoodsReceipt[]

  @@index([materialRequestId])
  @@index([status])
  @@index([siteId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                        String   @id @default(cuid())
  purchaseOrderId           String
  materialRequestItemId     String
  materialId                String?
  orderedQuantity           Decimal  @db.Decimal(15, 4)
  receivedQuantity          Decimal  @default(0) @db.Decimal(15, 4)
  note                      String?
  // 발주 시점 스냅샷
  itemNameSnapshot          String
  specSnapshot              String?
  unitSnapshot              String?
  disciplineCodeSnapshot    String?
  subDisciplineCodeSnapshot String?
  requestQuantitySnapshot   Decimal  @db.Decimal(15, 4)
  requestNoteSnapshot       String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  purchaseOrder       PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  materialRequestItem MaterialRequestItem @relation(fields: [materialRequestItemId], references: [id], onDelete: Restrict)
  goodsReceiptItems   GoodsReceiptItem[]

  @@index([purchaseOrderId])
  @@index([materialRequestItemId])
  @@map("purchase_order_items")
}

model PurchaseOrderStatusHistory {
  id              String               @id @default(cuid())
  purchaseOrderId String
  fromStatus      PurchaseOrderStatus?
  toStatus        PurchaseOrderStatus
  changedByUserId String?
  reason          String?              @db.Text
  createdAt       DateTime             @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_status_histories")
}

// ─── 입고/검수 ────────────────────────────────────────────────────────────────

model GoodsReceipt {
  id               String   @id @default(cuid())
  receiptNo        String   @unique  // GR-YYYYMMDD-NNNN
  purchaseOrderId  String
  receivedByUserId String
  receivedAt       DateTime
  memo             String?  @db.Text
  createdAt        DateTime @default(now())

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  items         GoodsReceiptItem[]

  @@index([purchaseOrderId])
  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id             String   @id @default(cuid())
  goodsReceiptId String
  poItemId       String
  quantity       Decimal  @db.Decimal(15, 4)
  inspectionNote String?  @db.Text
  createdAt      DateTime @default(now())

  goodsReceipt GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  poItem       PurchaseOrderItem @relation(fields: [poItemId], references: [id], onDelete: Restrict)

  @@index([goodsReceiptId])
  @@index([poItemId])
  @@map("goods_receipt_items")
}

// ─── 근로자 작업일보 ────────────────────────────────────────────────────────────

model WorkerDailyReport {
  id                  String               @id @default(cuid())
  workerId            String
  siteId              String
  attendanceLogId     String?              // AttendanceLog 연결 (soft ref)
  reportDate          DateTime             @db.Date
  // ── 고용/직종 스냅샷 ─────────────────────────────────────
  employmentType      ReportEmploymentType @default(DIRECT)
  jobTitle            String               @default("미설정")
  // ── 공종/작업사항 (표준 선택형) ──────────────────────────
  tradeFamilyCode     String?              // 공종계열 코드 (ELEC, MECH, CIVIL 등)
  tradeFamilyLabel    String?              // 공종계열 표시명
  tradeCode           String?              // 세부공종 코드 (ELECTRICAL, FIRE_ELEC 등)
  tradeLabel          String?              // 세부공종 표시명 (전기, 소방전기 등)
  taskCode            String?              // 작업사항 코드 (SLAB_CONDUIT 등)
  taskLabel           String?              // 작업사항 표시명 (슬라브 배관 등)
  workDetail          String?              @db.Text  // 세부 작업 설명 (자유입력)
  // ── 작업 위치 (선택형) ───────────────────────────────────
  buildingName        String?              // 동 (A동, B동 등)
  floorLabel          String?              // 층 (지하2층, 12층 등)
  locationDetail      String?              // 상세위치 (EPS실, 복도 등)
  locationDisplayName String?              // 조합 표시명 (A동 지하2층 EPS실)
  // ── 작업 3구조 ───────────────────────────────────────────
  yesterdayWork       String?              @db.Text
  todayWork           String?              @db.Text
  tomorrowWork        String?              @db.Text
  // ── 작업 분류 (레거시 — 공종/작업사항으로 대체) ──────────
  workType            String?
  processType         String?
  // ── 작업시간 ─────────────────────────────────────────────
  workStartTime       String?              // HH:mm
  workEndTime         String?              // HH:mm
  // ── 반복·공수 ────────────────────────────────────────────
  consecutiveDays     Int                  @default(1)    // 동일 작업 연속일수
  todayManDays        Decimal              @default(1.0)  @db.Decimal(4, 1)
  monthlyManDays      Decimal              @default(0)    @db.Decimal(6, 1)
  totalManDays        Decimal              @default(0)    @db.Decimal(8, 1)
  // ── 부가 정보 ────────────────────────────────────────────
  notes               String?              @db.Text
  materialUsedYn      Boolean              @default(false)
  materialNote        String?
  photos              String[]             @default([])
  // ── 복사 플래그 ──────────────────────────────────────────
  copiedFromPreviousYn Boolean             @default(false)
  copiedToTomorrowYn   Boolean             @default(false)
  // ── 관리자 확인 ──────────────────────────────────────────
  status              WorkerReportStatus   @default(WRITTEN)
  confirmedById       String?
  confirmedAt         DateTime?
  adminMemo           String?              @db.Text
  // ── TBM 확인 ─────────────────────────────────────────────
  tbmConfirmedYn      Boolean              @default(false)
  tbmConfirmedAt      DateTime?
  // ── 퇴근 시 건강이상 없음 확인 ─────────────────────────────
  healthCheckedYn     Boolean              @default(false)
  healthCheckedAt     DateTime?
  healthSignature     String?              @db.Text  // 서명 이미지 data URI
  // ── 작업완료 사진 (일반 photos와 별도) ──────────────────────
  workCompletionPhotos String[]            @default([])
  // ── 타임스탬프 ───────────────────────────────────────────
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([workerId, siteId, reportDate])
  @@index([siteId, reportDate])
  @@index([workerId, reportDate])
  @@index([status])
  @@index([tradeFamilyCode, tradeCode, taskCode])
  @@map("worker_daily_reports")
}

// ─── 현장별 위치 마스터 ─────────────────────────────────────────────────────

model SiteLocationMaster {
  id              String   @id @default(cuid())
  siteId          String
  buildingName    String               // 동 (A동, B동 등)
  floorOrder      Int      @default(0) // 정렬 순서 (지하 음수, 지상 양수)
  floorLabel      String               // 층 표시 (지하2층, 12층, 옥탑 등)
  detailLabel     String?              // 상세위치 (EPS실, 복도, 기계실 등)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, buildingName])
  @@index([siteId, isActive])
  @@map("site_location_masters")
}

// ─── 공종 계열 마스터 ───────────────────────────────────────────────────────

model TradeFamilyMaster {
  id          String   @id @default(cuid())
  code        String   @unique  // ELEC, MECH, CIVIL, ARCH, ETC
  label       String             // 전기계열, 기계계열, 토목계열 등
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trades TradeMaster[]
  tasks  TaskMaster[]

  @@map("trade_family_masters")
}

// ─── 세부 공종 마스터 ───────────────────────────────────────────────────────

model TradeMaster {
  id              String   @id @default(cuid())
  tradeFamilyId   String
  code            String   @unique  // ELECTRICAL, FIRE_ELEC, FIRE_MECH, TELECOM 등
  label           String             // 전기, 소방전기, 소방기계, 통신 등
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  family TradeFamilyMaster @relation(fields: [tradeFamilyId], references: [id], onDelete: Cascade)

  @@index([tradeFamilyId])
  @@map("trade_masters")
}

// ─── 작업사항 마스터 (계열 기준) ────────────────────────────────────────────

model TaskMaster {
  id              String   @id @default(cuid())
  tradeFamilyId   String               // 계열에 연결 (계열 공통 작업사항)
  tradeId         String?              // 특정 공종 전용이면 지정, null이면 계열 공통
  code            String   @unique     // SLAB_CONDUIT, WIRING, BOX_MOUNT 등
  label           String               // 슬라브 배관, 입선, 박스 취부 등
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  family TradeFamilyMaster @relation(fields: [tradeFamilyId], references: [id], onDelete: Cascade)

  @@index([tradeFamilyId])
  @@index([tradeId])
  @@map("task_masters")
}

// ═══════════════════════════════════════════════════════════
//  투입 전 필수 문서 패키지 (Onboarding Document Package)
// ═══════════════════════════════════════════════════════════

// ─── 근로자별 문서 패키지 집계 ──────────────────────────────
model WorkerDocumentPackage {
  id                 String                  @id @default(cuid())
  workerId           String
  siteId             String?
  scope              PackageScope            @default(GLOBAL)
  overallStatus      DocPackageOverallStatus @default(NOT_READY)
  requiredDocCount   Int                     @default(5)
  approvedDocCount   Int                     @default(0)
  rejectedDocCount   Int                     @default(0)
  pendingDocCount    Int                     @default(0)
  missingDocCount    Int                     @default(5)
  expiredDocCount    Int                     @default(0)
  lastSubmittedAt    DateTime?
  lastReviewedAt     DateTime?
  readyAt            DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site     Site?  @relation(fields: [siteId], references: [id], onDelete: SetNull)

  onboardingDocs OnboardingDocument[]

  @@unique([workerId, siteId])
  @@index([overallStatus])
  @@map("worker_document_packages")
}

// ─── 문서 개별 현재 상태 ─────────────────────────────────────
model OnboardingDocument {
  id                    String              @id @default(cuid())
  workerId              String
  siteId                String?
  packageId             String
  docType               OnboardingDocType
  status                OnboardingDocStatus @default(NOT_SUBMITTED)
  versionNo             Int                 @default(1)
  title                 String?
  contractId            String?             // doc_type=CONTRACT 시 계약 참조
  submittedAt           DateTime?
  reviewedAt            DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  expiresAt             DateTime?
  reviewerId            String?
  rejectionReason       String?
  latestSubmissionId    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  worker   Worker                @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site     Site?                 @relation(fields: [siteId], references: [id], onDelete: SetNull)
  package  WorkerDocumentPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  contract WorkerContract?       @relation(fields: [contractId], references: [id], onDelete: SetNull)

  submissions OnboardingDocSubmission[]
  reviews     OnboardingDocReview[]

  @@unique([workerId, siteId, docType])
  @@index([packageId, docType])
  @@index([status])
  @@map("worker_onboarding_documents")
}

// ─── 제출 이력 (재제출/버전 관리) ─────────────────────────────
model OnboardingDocSubmission {
  id                 String          @id @default(cuid())
  onboardingDocId    String
  workerId           String
  docType            OnboardingDocType
  submissionNo       Int
  statusSnapshot     OnboardingDocStatus
  submitMethod       DocSubmitMethod
  fileId             String?
  signedDocumentUrl  String?
  sourcePayload      Json?
  submittedByWorkerId String?
  submittedAt        DateTime        @default(now())
  note               String?
  createdAt          DateTime        @default(now())

  onboardingDoc OnboardingDocument @relation(fields: [onboardingDocId], references: [id], onDelete: Cascade)
  file          FileRecord?        @relation(fields: [fileId], references: [id], onDelete: SetNull)
  reviews       OnboardingDocReview[]

  @@index([onboardingDocId])
  @@index([workerId, docType])
  @@map("worker_doc_submissions")
}

// ─── 검토 이력 (승인/반려) ────────────────────────────────────
model OnboardingDocReview {
  id               String          @id @default(cuid())
  onboardingDocId  String
  submissionId     String?
  action           DocReviewAction
  reviewerId       String
  reason           String?
  createdAt        DateTime        @default(now())

  onboardingDoc OnboardingDocument       @relation(fields: [onboardingDocId], references: [id], onDelete: Cascade)
  submission    OnboardingDocSubmission?  @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  reviewer      AdminUser                @relation(fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([onboardingDocId])
  @@index([reviewerId])
  @@map("worker_doc_reviews")
}

// ─── 문서 템플릿 (개인정보동의서/건강각서/안전서류) ──────────────
model OnboardingDocTemplate {
  id            String            @id @default(cuid())
  docType       OnboardingDocType
  title         String
  contentHtml   String?
  contentJson   Json?
  versionNo     Int               @default(1)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([docType, isActive])
  @@map("onboarding_doc_templates")
}

// ─── 토큰 블랙리스트 (로그아웃 시 토큰 무효화, DB 영속) ─────────
model TokenBlacklist {
  id        String   @id @default(cuid())
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("token_blacklist")
}
