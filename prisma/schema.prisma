  userId     String
  companyId  String
  siteId     String
  isActive   Boolean   @default(true)
  assignedAt DateTime  @default(now())
  assignedBy String
  revokedAt  DateTime?
  revokedBy  String?
  createdAt  DateTime  @default(now())
