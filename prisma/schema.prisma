  blockedBy       String?   // AdminUser.id
  lastLoginAt     DateTime?
  lastLatitude    Float?    // 마지막 위치 스냅샷
  lastLongitude   Float?
  fcmToken        String?
  approvedAt      DateTime?
  approvedBy      String?
  revokedAt       DateTime?
  revokeReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([isBlocked])
  @@map("worker_devices")
}

