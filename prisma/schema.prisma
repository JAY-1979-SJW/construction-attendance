}

// ─── Phase 6: 신분증 스캔/OCR/마스킹/권한관리 ─────────────

model WorkerIdentityDocument {
  id               String         @id @default(cuid())
  workerId         String
  documentType     IdDocumentType @default(UNKNOWN)
  originalFileKey  String
  maskedFileKey    String?
  thumbnailFileKey String?
  fileMimeType     String
  fileSize         Int
  ocrRawText       String?
  ocrRawJson       Json?
  parsedJson       Json?
  scanStatus       IdScanStatus   @default(UPLOADED)
  reviewStatus     IdReviewStatus @default(PENDING_REVIEW)
  uploadedBy       String
  reviewedBy       String?
  reviewedAt       DateTime?
  rejectedReason   String?
  isLatest         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  worker        Worker                   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  sensitiveData WorkerSensitiveIdentity?
