  presenceCheckAmEnd                String   @default("11:30")
  presenceCheckPmStart              String   @default("13:30")
  presenceCheckPmEnd                String   @default("16:30")
  // === 출퇴근 운영 기준 ===
  checkInStart                      String   @default("07:00")
  checkOutEnd                       String   @default("16:30")
  tardyMinutes                      Int      @default(0)
  earlyLeaveMinutes                 Int      @default(30)
