  dedupeReason        String?
  matchedSiteId       String?
  matchedSiteName     String?
  candidatesJson      Json?
  // AI 보조
  aiDecision          String?
  aiConfidence        Float?
  aiExplanation       String?
  // 사용자 결정
  userDecision        String?                        // USE_EXISTING, REGISTER_NEW, CANCEL
  //
  validationStatus    BulkImportRowValidationStatus  @default(READY)
  validationMessage   String?
  approvedBy          String?
  approvedAt          DateTime?
  importedSiteId      String?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  job         BulkSiteImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importedSite Site?             @relation(fields: [importedSiteId], references: [id], onDelete: SetNull)

  @@index([jobId, validationStatus])
  @@map("bulk_site_import_rows")
}

// ─── 근로자 일괄 업로드 스테이징 ──────────────────────────

model BulkWorkerImportJob {
