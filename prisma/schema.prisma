// ─── Models ──────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  companyId    String?   // COMPANY_ADMIN 전용, 플랫폼 관리자는 null
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company                 Company?              @relation("AdminUserCompany", fields: [companyId], references: [id], onDelete: Restrict)
  siteAdminAssignments    SiteAdminAssignment[]
  siteAccessGroupUsers    UserSiteAccessGroup[]
  processedDeviceRequests DeviceChangeRequest[] @relation("ProcessedBy")
  auditLogs               AdminAuditLog[]
  onboardingDocReviews    OnboardingDocReview[]

  @@index([companyId])
  @@map("admin_users")
}

// ─── v2: Company (Subcontractor 대체) ────────────────────

model Company {
  id                 String        @id @default(cuid())
  companyCode        String?       @unique
  companyName        String
  businessNumber     String?       @unique
  corpNumber         String?
  representativeName String?
  companyType        CompanyType   @default(OTHER)
  contactName        String?
  contactPhone       String?
  email              String?
  address            String?
  isActive           Boolean       @default(true)
  // 플랫폼 관리 필드
  status             CompanyStatus @default(ACTIVE)
  planType           String?       // 요금제 유형 (free/standard/premium 등)
  expiresAt          DateTime?     // 사용기간 만료일
  featureFlagsJson   Json?         // 업체별 기능 ON/OFF
  notes              String?
  // 외부회사 사업자 인증 (PARTNER/SUBCONTRACTOR 등 외부 업체용)
  externalVerificationStatus CompanyVerificationStatus?
  verificationNotes          String?
  verifiedAt                 DateTime?
  verifiedBy                 String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  adminUsers            AdminUser[]               @relation("AdminUserCompany")
  joinRequests          CompanyJoinRequest[]
  workerAssignments     WorkerCompanyAssignment[]
  siteAssignments       SiteCompanyAssignment[]
  workerSiteAssignments WorkerSiteAssignment[]
  siteAdminAssignments  SiteAdminAssignment[]
  insuranceStatuses     WorkerInsuranceStatus[]
  workerDocuments       WorkerDocument[]
  laborCostSummaries    LaborCostSummary[]
  companySettlements    CompanySettlement[]
  // 분쟁방어 패널
  disputeCases          DisputeCase[]
  defensePanelSnapshots DefensePanelSnapshot[]
  documentDeliveryLogs  DocumentDeliveryLog[]
  attendanceAdjustmentLogs AttendanceAdjustmentLog[]
  // 관리행위
  warningRecords        WorkerWarningRecord[]
  explanationRequests   WorkerExplanationRequest[]
  noticeRecords         WorkerNoticeRecord[]
  terminationReviews    WorkerTerminationReview[]
  terminationSnapshots  WorkerTerminationSnapshot[]
  insuranceSubmissions  InsuranceSubmissionHistory[]

  @@map("companies")
}

model Worker {
  id            String              @id @default(cuid())
  workerCode    String?             @unique
  name          String
  phone         String?             @unique
  jobTitle      String              @default("미설정")
  isActive      Boolean             @default(true)
  // ── 회원가입·승인 상태 ────────────────────────────────────
  accountStatus WorkerAccountStatus @default(APPROVED)  // 기존 어드민 생성 계정은 APPROVED
  username      String?             @unique              // 자가 회원가입 시 아이디 (선택)
  email         String?             @unique              // 이메일 (OAuth 또는 이메일/비번 로그인)
  passwordHash  String?                                  // 이메일/비번 로그인용 (OAuth 사용 시 null)
  birthDate     String?                                  // 생년월일 YYYYMMDD (선택)
  // 반려 사유
  rejectReason  String?
  reviewedAt    DateTime?
  reviewedBy    String?

  // ── 노무 관리 확장 필드 ──────────────────────────────────
  residentIdMasked          String?
  foreignerYn               Boolean          @default(false)
  nationalityCode           String?          @default("KR")
  /// @deprecated — 레거시 평문 은행명. 신규 구조: bankAccountSecure.bankName
  /// 삭제 준비 완료 (migrate-bank-legacy.mjs 이행 후 bank_legacy_column_drop_PENDING migration 적용)
  bankName                  String?
  /// @deprecated — 레거시 평문 계좌번호. 보안 원칙상 신규 이행 없음, 재입력 필요
  /// 삭제 준비 완료 (bank_legacy_column_drop_PENDING migration 참조)
  bankAccount               String?
  employmentType            EmploymentType   @default(DAILY_CONSTRUCTION)
