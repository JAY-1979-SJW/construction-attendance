  @@index([workerId])
  @@map("worker_identity_documents")
}

model WorkerSensitiveIdentity {
  id                      String    @id @default(cuid())
  workerId                String    @unique
  sourceDocumentId        String    @unique
  legalName               String?
  birthDate               String?
  gender                  String?
  nationality             String?
  residentType            String?
  idNumberEncrypted       String?
  idNumberMasked          String?
  addressEncrypted        String?
  addressMasked           String?
  licenseNumberEncrypted  String?
  licenseNumberMasked     String?
  issueDate               String?
  expiryDate              String?
  foreignerYn             Boolean        @default(false)
  verificationStatus      IdReviewStatus @default(PENDING_REVIEW)
  verifiedBy              String?
  verifiedAt              DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  worker         Worker                 @relation(fields: [workerId], references: [id], onDelete: Cascade)
  sourceDocument WorkerIdentityDocument @relation(fields: [sourceDocumentId], references: [id])

  @@map("worker_sensitive_identities")
}

model IdentityAccessLog {
  id           String               @id @default(cuid())
  workerId     String
  documentId   String
  actionType   IdentityAccessAction
  actorUserId  String
  actorRole    String
  ipAddress    String?
  reason       String?
  createdAt    DateTime             @default(now())

  document WorkerIdentityDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([documentId])
  @@map("identity_access_logs")
}
