// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum AttendanceStatus {
  WORKING           // 출근 후 미퇴근 (당일)
  COMPLETED         // 정상 출퇴근 완료
  MISSING_CHECKOUT  // 퇴근 미기록 (익일 04:00 스케줄러 전환)
  ADJUSTED          // 관리자가 시간 수정한 기록
  ADMIN_MANUAL      // 관리자가 직접 생성한 기록
  EXCEPTION         // 예외 처리 (GPS 실패 등 관리자 승인)
}

enum AttendanceEventType {
  CHECK_IN              // 출근
  MOVE                  // 현장 이동 (이동형 근무)
  CHECK_OUT             // 퇴근
  AUTO_CHECK_OUT        // 자동 퇴근 처리
  EXCEPTION_CHECK_OUT   // 반경 밖 예외 퇴근
  ADMIN_ADJUSTMENT      // 관리자 수동 조정
}

enum DeviceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OtpPurpose {
  LOGIN
  DEVICE_CHANGE
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum TimeBucket {
  AM
  PM
}

enum PresenceCheckStatus {
  PENDING
  COMPLETED
  MISSED           // legacy, replaced by NO_RESPONSE
  OUT_OF_GEOFENCE
  LOW_ACCURACY     // legacy
  SKIPPED          // legacy
  NO_RESPONSE      // new: expired without response
  REVIEW_REQUIRED  // new: needs admin review
  CANCELED         // new: admin canceled
  MANUALLY_CONFIRMED  // new: admin approved as present
  MANUALLY_REJECTED   // new: admin confirmed absence/violation
}

// ─── 노무 관리 Enums ──────────────────────────────────────

enum EmploymentType {
  REGULAR              // 상용근로자
  DAILY_CONSTRUCTION   // 건설 일용근로자
  BUSINESS_33          // 3.3% 사업소득
  OTHER                // 기타
}

enum IncomeType {
  SALARY           // 급여 (상용)
  DAILY_WAGE       // 일용근로소득
  BUSINESS_INCOME  // 사업소득
}

enum OrganizationType {
  DIRECT         // 직영
  SUBCONTRACTOR  // 협력사 소속
}

enum ContractType {
  EMPLOYMENT  // 근로계약
  DAILY       // 일용계약
  SERVICE     // 용역계약 (3.3%)
}

enum WorkConfirmationStatus {
  DRAFT      // 확정 전 (초안)
  CONFIRMED  // 확정 완료
  EXCLUDED   // 제외 (무효)
}

enum ConfirmedWorkType {
  FULL_DAY   // 정규 1공수
  HALF_DAY   // 반일 0.5공수
  OVERTIME   // 연장근무
  NIGHT      // 야간근무
  HOLIDAY    // 휴일근무
  INVALID    // 무효 출역
}

enum AttendanceDayPresenceStatus {
  NORMAL           // 정상
  REVIEW_REQUIRED  // 검토 필요
  OUT_OF_GEOFENCE  // 위치이탈
  NO_RESPONSE      // 미응답
  MISSING_CHECKOUT // 퇴근 미기록
  INVALID          // 무효
}

enum FilingExportType {
  DAILY_WAGE_NTS         // 일용근로소득 지급명세서
  BUSINESS_INCOME_NTS    // 사업소득 간이지급명세서
  EI_DAILY_REPORT        // 고용보험 근로내용확인신고
  NP_BASE                // 국민연금 판정 기초
  HI_BASE                // 건강보험 판정 기초
  RETIREMENT_MUTUAL_BASE // 퇴직공제 기초
  LABOR_COST_SUMMARY     // 노무비 집계
}

enum MonthClosingStatus {
  OPEN
  CLOSING
  CLOSED
  REOPENED
}

enum ClosingScope {
  GLOBAL
  SITE
}

enum CorrectionDomainType {
  WORK_CONFIRMATION
  INSURANCE
  WAGE
  WITHHOLDING
  RETIREMENT_MUTUAL
  EXPORT
  MONTH_CLOSING
}

enum CorrectionActionType {
  CREATE
  UPDATE
  DELETE
  REOPEN
  RECALCULATE
  MANUAL_OVERRIDE
}

enum RetirementReportStatus {
  READY
  EXPORTED
  CORRECTED
}

enum RetirementMutualStatus {
  YES             // 대상
  NO              // 비대상
  PENDING_REVIEW  // 확인 필요
}

// ─── v2 신규 Enums ────────────────────────────────────────

enum CompanyType {
  SELF                       // 자사
  PARTNER                    // 협력사
  SUBCONTRACTOR              // 하도사
  SECOND_TIER_SUBCONTRACTOR  // 재하도사
  LABOR_AGENCY               // 인력사무소
  SOLE_PROPRIETOR            // 개인사업자
  OTHER
}

enum WorkerCompanyEmploymentType {
  DIRECT       // 직영
  SUBCONTRACT  // 하도
  SECOND_TIER  // 재하도
  DAILY        // 일용
  REGULAR      // 상용
  OUTSOURCED   // 외주
}

enum ContractorTierType {
  PRIME  // 원청
  TIER1  // 1차하도
  TIER2  // 2차하도
  OTHER
}

enum SiteContractType {
  DIRECT_WORK  // 직영공사
  SUBCONTRACT  // 하도급
  SUPPLY       // 자재공급
  SERVICE      // 용역
  OTHER
}

enum InsuranceEnrollStatus {
  ENROLLED          // 가입
  NOT_ENROLLED      // 미가입
  EXEMPT            // 적용제외
  PENDING           // 확인중
  DOCUMENT_PENDING  // 서류대기
  LOST              // 상실
  UNKNOWN           // 불명확
}

enum InsuranceReportingStatus {
  NOT_CHECKED               // 미확인
  VERIFIED                  // 확인완료
  ACQUISITION_REQUIRED      // 취득신고필요
  LOSS_REQUIRED             // 상실신고필요
  EXCEPTION_REVIEW_REQUIRED // 예외확인필요
}

enum WorkerDocumentType {
  ID_CARD       // 신분증
  INSURANCE_DOC // 4대보험증빙
  CONTRACT      // 근로계약서
  SAFETY_CERT   // 안전교육이수증
  OTHER         // 기타
}

enum WorkerDocumentStatus {
  UPLOADED          // 업로드완료
  REVIEW_PENDING    // 검토대기
  APPROVED          // 검토완료
  NEEDS_SUPPLEMENT  // 보완필요
  EXPIRED           // 만료
}

enum BulkImportJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum BulkImportRowValidationStatus {
  READY        // 정상
  NEEDS_REVIEW // 검토필요
  FAILED       // 지오코딩/검증 실패
  APPROVED     // 관리자 승인
  IMPORTED     // 실제 등록 완료
}

enum AuditActorType {
  ADMIN
  WORKER
  SYSTEM
}

// ─── Phase 6: 신분증 Enums ────────────────────────────────

enum IdDocumentType {
  NATIONAL_ID
  DRIVER_LICENSE
  ALIEN_REGISTRATION
  UNKNOWN
}

enum IdScanStatus {
  UPLOADED
  OCR_RUNNING
  OCR_DONE
  PARSED
  FAILED
}

enum IdReviewStatus {
  PENDING_REVIEW
  VERIFIED
  REJECTED
  RESCAN_REQUIRED
  ARCHIVED
}

enum IdentityAccessAction {
  UPLOAD
  VIEW_ORIGINAL
  VIEW_MASKED
  DOWNLOAD_ORIGINAL
  DOWNLOAD_MASKED
  OCR_RUN
  APPLY_TO_WORKER
  VERIFY
  REJECT
  DELETE
}

// ─── Models ──────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  processedDeviceRequests DeviceChangeRequest[] @relation("ProcessedBy")
  auditLogs               AdminAuditLog[]

  @@map("admin_users")
}

// ─── v2: Company (Subcontractor 대체) ────────────────────

model Company {
  id                 String      @id @default(cuid())
  companyCode        String?     @unique
  companyName        String
  businessNumber     String?     @unique
  corpNumber         String?
  representativeName String?
  companyType        CompanyType @default(OTHER)
  contactName        String?
  contactPhone       String?
  email              String?
  address            String?
  isActive           Boolean     @default(true)
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Relations
  workerAssignments     WorkerCompanyAssignment[]
  siteAssignments       SiteCompanyAssignment[]
  workerSiteAssignments WorkerSiteAssignment[]
  insuranceStatuses     WorkerInsuranceStatus[]
  workerDocuments       WorkerDocument[]
  laborCostSummaries    LaborCostSummary[]
  companySettlements    CompanySettlement[]

  @@map("companies")
}

model Worker {
  id          String   @id @default(cuid())
  workerCode  String?  @unique
  name        String
  phone       String   @unique
  jobTitle    String
  isActive    Boolean  @default(true)

  // ── 노무 관리 확장 필드 ──────────────────────────────────
  residentIdMasked          String?
  foreignerYn               Boolean          @default(false)
  nationalityCode           String?          @default("KR")
  bankName                  String?
  bankAccount               String?
  employmentType            EmploymentType   @default(DAILY_CONSTRUCTION)
  incomeType                IncomeType       @default(DAILY_WAGE)
  organizationType          OrganizationType @default(DIRECT)
  skillLevel                String?
  retirementMutualTargetYn  Boolean          @default(false)
  retirementMutualStatus    RetirementMutualStatus @default(PENDING_REVIEW)
  fourInsurancesEligibleYn  Boolean          @default(true)
  // ── Phase 4 확장 필드 ───────────────────────────────────
  residentType              String?          // LOCAL | FOREIGNER
  foreignTaxSpecialYn       Boolean          @default(false)
  insuranceExceptionYn      Boolean          @default(false)
  insuranceExceptionReason  String?
  taxExceptionYn            Boolean          @default(false)
  taxExceptionReason        String?
  // ── Phase 6 신분증 ─────────────────────────────────────
  idVerificationStatus       IdReviewStatus?
  latestIdentityDocumentId   String?
  identityLastReviewedAt     DateTime?
  identityLastReviewedBy     String?
  // ───────────────────────────────────────────────────────

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  devices                    WorkerDevice[]
  attendanceLogs             AttendanceLog[]
  deviceChangeRequests       DeviceChangeRequest[]
  otpVerifications           OtpVerification[]
  attendanceEvents           AttendanceEvent[]
  presenceChecks             PresenceCheck[]
  contracts                  WorkerContract[]
  attendanceDays             AttendanceDay[]
  workConfirmations          MonthlyWorkConfirmation[]
  insuranceSnapshots         InsuranceEligibilitySnapshot[]
  wageCalculations           WageCalculation[]
  withholdingCalcs           WithholdingCalculation[]
  retirementRecords          RetirementMutualDailyRecord[]
  retirementMutualWorkers    RetirementMutualWorker[]
  retirementMonthlySummaries RetirementMutualMonthlySummary[]
  onboardingChecklists       OnboardingChecklist[]
  identityDocuments          WorkerIdentityDocument[]
  sensitiveIdentity          WorkerSensitiveIdentity?
  // v2 관계
  companyAssignments         WorkerCompanyAssignment[]
  siteAssignments            WorkerSiteAssignment[]
  insuranceStatuses          WorkerInsuranceStatus[]
  workerDocuments            WorkerDocument[]

  @@map("workers")
}

model Site {
  id                 String    @id @default(cuid())
  siteCode           String?   @unique
  name               String
  address            String
  latitude           Float
  longitude          Float
  allowedRadius      Int       @default(100) // meters
  qrToken            String    @unique
  isActive           Boolean   @default(true)
  openedAt           DateTime?
  closedAt           DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  checkInLogs    AttendanceLog[]   @relation("CheckInSite")
  checkOutLogs   AttendanceLog[]   @relation("CheckOutSite")
  events         AttendanceEvent[]
  presenceChecks PresenceCheck[]
  contracts      WorkerContract[]
  attendanceDays AttendanceDay[]
  workConfirmations          MonthlyWorkConfirmation[]
  retirementRecords          RetirementMutualDailyRecord[]
  monthClosings              MonthClosing[]
  retirementMutualSite       RetirementMutualSite?
  retirementMonthlySummaries RetirementMutualMonthlySummary[]
  laborCostSummaries         LaborCostSummary[]
  companySettlements         CompanySettlement[]
  onboardingChecklists       OnboardingChecklist[]
  closingSnapshots           MonthClosingSnapshot[]
  preflightRuns              PreflightCheckRun[]
  // v2 관계
  companyAssignments         SiteCompanyAssignment[]
  workerAssignments          WorkerSiteAssignment[]
  bulkImportRows             BulkSiteImportRow[]

  @@map("sites")
}

// ─── v2: Worker-Company 소속 이력 ─────────────────────────

model WorkerCompanyAssignment {
  id             String                      @id @default(cuid())
  workerId       String
  companyId      String
  employmentType WorkerCompanyEmploymentType @default(DAILY)
  contractorTier ContractorTierType          @default(PRIME)
  roleTitle      String?
  validFrom      DateTime
  validTo        DateTime?
  isPrimary      Boolean                     @default(false)
  notes          String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  worker  Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([workerId, validFrom])
  @@index([companyId])
  @@map("worker_company_assignments")
}

// ─── v2: Site-Company 배정 ────────────────────────────────

model SiteCompanyAssignment {
  id           String          @id @default(cuid())
  siteId       String
  companyId    String
  contractType SiteContractType @default(SUBCONTRACT)
  startDate    DateTime
  endDate      DateTime?
  managerName  String?
  managerPhone String?
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([siteId])
  @@index([companyId])
  @@map("site_company_assignments")
}

// ─── v2: Worker-Site 배정 이력 ────────────────────────────

model WorkerSiteAssignment {
  id           String    @id @default(cuid())
  workerId     String
  siteId       String
  companyId    String
  assignedFrom DateTime
  assignedTo   DateTime?
  tradeType    String?   // 공종
  isPrimary    Boolean   @default(false)
  isActive     Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  worker  Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Restrict)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([workerId, isActive])
  @@index([siteId])
  @@index([companyId])
  @@map("worker_site_assignments")
}

// ─── v2: 4대보험 상태 ─────────────────────────────────────

model WorkerInsuranceStatus {
  id                        String                  @id @default(cuid())
  workerId                  String
  companyId                 String
  nationalPensionStatus     InsuranceEnrollStatus   @default(UNKNOWN)
  healthInsuranceStatus     InsuranceEnrollStatus   @default(UNKNOWN)
  employmentInsuranceStatus InsuranceEnrollStatus   @default(UNKNOWN)
  industrialAccidentStatus  InsuranceEnrollStatus   @default(UNKNOWN)
  dailyWorkerFlag           Boolean                 @default(false)
  constructionWorkerFlag    Boolean                 @default(true)
  acquisitionDate           DateTime?
  lossDate                  DateTime?
  reportingStatus           InsuranceReportingStatus @default(NOT_CHECKED)
  verificationDate          DateTime?
  verifiedBy                String?
  notes                     String?
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt

  worker  Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([workerId])
  @@index([companyId])
  @@map("worker_insurance_statuses")
}

// ─── v2: 파일 메타데이터 ──────────────────────────────────

model FileRecord {
  id               String   @id @default(cuid())
  storageProvider  String   @default("LOCAL") // LOCAL | NAS | S3
  path             String
  originalFilename String
  mimeType         String
  sizeBytes        Int
  sha256Hash       String?
  isEncrypted      Boolean  @default(true)
  uploadedBy       String
  uploadedAt       DateTime @default(now())

  workerDocuments  WorkerDocument[]

  @@index([uploadedAt])
  @@map("file_records")
}

// ─── v2: 근로자 문서 ──────────────────────────────────────

model WorkerDocument {
  id           String               @id @default(cuid())
  workerId     String
  companyId    String?
  siteId       String?
  documentType WorkerDocumentType
  fileId       String
  status       WorkerDocumentStatus @default(UPLOADED)
  expiresAt    DateTime?
  reviewedBy   String?
  reviewedAt   DateTime?
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  worker  Worker     @relation(fields: [workerId], references: [id], onDelete: Cascade)
  company Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  file    FileRecord @relation(fields: [fileId], references: [id], onDelete: Restrict)

  @@index([workerId])
  @@index([status])
  @@map("worker_documents")
}

// ─── v2: 현장 일괄 업로드 ────────────────────────────────

model BulkSiteImportJob {
  id               String              @id @default(cuid())
  uploadedBy       String
  originalFilename String
  status           BulkImportJobStatus @default(PENDING)
  totalRows        Int                 @default(0)
  readyRows        Int                 @default(0)
  failedRows       Int                 @default(0)
  approvedRows     Int                 @default(0)
  importedRows     Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  rows BulkSiteImportRow[]

  @@index([createdAt])
  @@map("bulk_site_import_jobs")
}

model BulkSiteImportRow {
  id                  String                         @id @default(cuid())
  jobId               String
  rowNumber           Int
  siteName            String
  rawAddress          String
  normalizedAddress   String?
  latitude            Float?
  longitude           Float?
  allowedRadiusMeters Int?
  validationStatus    BulkImportRowValidationStatus  @default(READY)
  validationMessage   String?
  approvedBy          String?
  approvedAt          DateTime?
  importedSiteId      String?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt

  job         BulkSiteImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  importedSite Site?             @relation(fields: [importedSiteId], references: [id], onDelete: SetNull)

  @@index([jobId, validationStatus])
  @@map("bulk_site_import_rows")
}

// ─── v2: 범용 감사 로그 ──────────────────────────────────

model AuditLog {
  id           String         @id @default(cuid())
  actorUserId  String?
  actorType    AuditActorType @default(SYSTEM)
  actionType   String
  targetType   String?
  targetId     String?
  summary      String
  metadataJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime       @default(now())

  @@index([actorUserId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@index([actionType])
  @@map("audit_logs")
}

// ─── Device 관리 ──────────────────────────────────────────

model WorkerDevice {
  id              String    @id @default(cuid())
  workerId        String
  deviceToken     String    @unique
  deviceName      String
  fingerprintHash String?
  isPrimary       Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  fcmToken        String?
  approvedAt      DateTime?
  approvedBy      String?
  revokedAt       DateTime?
  revokeReason    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("worker_devices")
}

model OtpVerification {
  id          String     @id @default(cuid())
  phone       String
  code        String
  purpose     OtpPurpose
  expiresAt   DateTime
  verifiedAt  DateTime?
  createdAt   DateTime   @default(now())

  workerId String?
  worker   Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@map("otp_verifications")
}

model DeviceChangeRequest {
  id             String              @id @default(cuid())
  workerId       String
  oldDeviceToken String?
  newDeviceToken String
  newDeviceName  String
  reason         String
  status         DeviceRequestStatus @default(PENDING)
  requestedAt    DateTime            @default(now())
  processedAt    DateTime?
  processedBy    String?

  worker    Worker     @relation(fields: [workerId], references: [id])
  adminUser AdminUser? @relation("ProcessedBy", fields: [processedBy], references: [id])

  @@map("device_change_requests")
}

// ─── 출퇴근 ──────────────────────────────────────────────

model AttendanceLog {
  id              String           @id @default(cuid())
  workerId        String
  siteId          String
  checkOutSiteId  String?
  workDate        DateTime         @db.Date
  checkInAt       DateTime?
  checkOutAt      DateTime?
  checkInLat      Float?
  checkInLng      Float?
  checkOutLat     Float?
  checkOutLng     Float?
  checkInDistance  Float?
  checkOutDistance Float?
  checkInWithinRadius  Boolean?
  checkOutWithinRadius Boolean?
  qrToken         String?          // nullable: 직접출근 시 null
  isDirectCheckIn Boolean          @default(false)
  status          AttendanceStatus @default(WORKING)
  exceptionReason String?
  adminNote       String?
  deviceTokenSnapshot String?
  // ── v2 회사 스냅샷 ───────────────────────────────────────
  companyId              String?
  companyNameSnapshot    String?
  employmentTypeSnapshot String?
  tradeTypeSnapshot      String?
  // ────────────────────────────────────────────────────────
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  worker        Worker  @relation(fields: [workerId], references: [id])
  checkInSite   Site    @relation("CheckInSite", fields: [siteId], references: [id])
  checkOutSite  Site?   @relation("CheckOutSite", fields: [checkOutSiteId], references: [id])
  events         AttendanceEvent[]
  presenceChecks PresenceCheck[]

  @@unique([workerId, siteId, workDate])
  @@index([workDate])
  @@index([siteId, workDate])
  @@index([companyId, workDate])
  @@map("attendance_logs")
}

model AttendanceEvent {
  id               String              @id @default(cuid())
  attendanceLogId  String
  workerId         String
  eventType        AttendanceEventType
  siteId           String?
  companyId        String?
  occurredAt       DateTime            @default(now())
  latitude         Float?
  longitude        Float?
  accuracy         Float?
  distanceFromSite Float?
  withinRadius     Boolean?
  deviceTokenSnapshot String?
  reason           String?
  memo             String?

  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  worker        Worker        @relation(fields: [workerId], references: [id])
  site          Site?         @relation(fields: [siteId], references: [id])

  @@index([attendanceLogId])
  @@index([workerId, occurredAt])
  @@map("attendance_events")
}

// ─── 앱 설정 ──────────────────────────────────────────────

model AppSettings {
  id                                String   @id @default("singleton")
  planType                          String   @default("FREE")
  presenceCheckFeatureAvailable     Boolean  @default(false)
  presenceCheckEnabled              Boolean  @default(false)
  presenceCheckAmEnabled            Boolean  @default(true)
