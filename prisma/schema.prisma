  adminDisplayName                  String   @default("")
  adminContact                      String   @default("")
  requireReasonOnEdit               Boolean  @default(false)
  keepEditHistory                   Boolean  @default(true)
  confirmBeforeSave                 Boolean  @default(false)
  // === 현장 운영 기본값 ===
  siteDefaultStatus                 String   @default("ACTIVE")
  siteEndingWarnDays                Int      @default(30)
  siteDefaultSort                   String   @default("endDate_asc")
  siteAutoReview                    Boolean  @default(true)
  // 미출근 확인필요 기준: 이 수 이상 미출근 시 확인필요 처리 (기본 2명)
