  explanationRequests        WorkerExplanationRequest[]
  noticeRecords              WorkerNoticeRecord[]
  terminationReviews         WorkerTerminationReview[]
  terminationSnapshots       WorkerTerminationSnapshot[]
  // 현장 운영 기록 (v3)
