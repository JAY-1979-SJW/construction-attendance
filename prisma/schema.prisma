// ─── 출퇴근 ──────────────────────────────────────────────

model AttendanceLog {
  id              String           @id @default(cuid())
  workerId        String
  siteId          String
  checkOutSiteId  String?
  workDate        DateTime         @db.Date
  checkInAt       DateTime?
  checkOutAt      DateTime?
  checkInLat      Float?
  checkInLng      Float?
  checkOutLat     Float?
  checkOutLng     Float?
  checkInDistance  Float?
  checkOutDistance Float?
  checkInWithinRadius  Boolean?
  checkOutWithinRadius Boolean?
  qrToken         String?          // nullable: 직접출근 시 null
