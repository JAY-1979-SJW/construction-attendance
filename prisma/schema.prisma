  retirementMutualLockedYn    Boolean            @default(false)
  closedBy                    String?
  closedAt                    DateTime?
  reopenedBy                  String?
  reopenedAt                  DateTime?
  reopenReason                String?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  site          Site?          @relation(fields: [siteId], references: [id], onDelete: SetNull)
  filingExports FilingExport[]
  snapshots     MonthClosingSnapshot[]

  @@unique([monthKey, closingScope, siteId])
  @@index([monthKey])
  @@map("month_closings")
}

model RetirementMutualSite {
