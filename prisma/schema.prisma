  worker          Worker           @relation(fields: [workerId], references: [id], onDelete: Cascade)
  wageCalculation WageCalculation? @relation(fields: [wageCalculationId], references: [id], onDelete: SetNull)

  @@unique([workerId, monthKey])
  @@index([monthKey])
  @@map("withholding_calculations")
}

model RetirementMutualDailyRecord {
  id                   String  @id @default(cuid())
  workerId             String
  siteId               String
  workDate             String  // 'YYYY-MM-DD'
  monthKey             String  // 'YYYY-MM'
  eligibleYn            Boolean  @default(true)
  recognizedWorkUnit    Decimal  @default(1.0) @db.Decimal(4, 2)
