  updatedAt             DateTime @updatedAt

  worker       Worker                   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site         Site                     @relation(fields: [siteId], references: [id], onDelete: Restrict)
  confirmation MonthlyWorkConfirmation? @relation(fields: [sourceConfirmationId], references: [id], onDelete: SetNull)

  @@unique([workerId, siteId, workDate])
  @@index([workerId, monthKey])
  @@index([monthKey])
  @@map("retirement_mutual_daily_records")
}

model FilingExport {
  id                    String           @id @default(cuid())
  monthKey              String           // 'YYYY-MM'
  exportType            FilingExportType
  status                String           @default("PENDING")
  filePath              String?
  rowCount              Int              @default(0)
  snapshotJson          Json?
  createdBy             String?
  createdAt             DateTime         @default(now())
  monthClosingId        String?
  versionNo             Int              @default(1)
  isLatestYn            Boolean          @default(true)
  outdatedYn            Boolean          @default(false)
  exportScopeJson       Json?
  generatedSnapshotJson Json?
  templateCode          String?
  fileFormat            String           @default("CSV")
  institutionType       String?
  downloadCount         Int              @default(0)
  lastDownloadedAt      DateTime?
  siteId                String?
  yearMonth             String?
  lastDownloadedBy      String?
  lastPreflightStatus   String?

  monthClosing MonthClosing? @relation(fields: [monthClosingId], references: [id], onDelete: SetNull)

  @@index([monthKey])
  @@index([exportType])
  @@map("filing_exports")
}

model MonthClosing {
  id                          String             @id @default(cuid())
  monthKey                    String             // 'YYYY-MM'
  siteId                      String?
  closingScope                ClosingScope       @default(GLOBAL)
  status                      MonthClosingStatus @default(OPEN)
  precheckPassedYn            Boolean            @default(false)
  closingStartedAt            DateTime?
  closingStartedBy            String?
  workConfirmationLockedYn    Boolean            @default(false)
  insuranceLockedYn           Boolean            @default(false)
