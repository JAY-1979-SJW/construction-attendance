// ─── 노무 관리 Models ─────────────────────────────────────

model WorkerContract {
  id                       String       @id @default(cuid())
  workerId                 String
  siteId                   String?
  contractType             ContractType @default(DAILY)
  startDate                String       // 'YYYY-MM-DD'
  endDate                  String?
  dailyWage                Int          @default(0)
  monthlySalary            Int?
  hourlyRate               Int?
  overtimeRate             Decimal?     @db.Decimal(4, 2)
  nightRate                Decimal?     @db.Decimal(4, 2)
  holidayRate              Decimal?     @db.Decimal(4, 2)
  halfDayRule              String       @default("HALF")
  taxRuleType              String       @default("DAILY_WAGE")
  insuranceRuleType        String       @default("DEFAULT")
  retirementMutualRuleType String       @default("DEFAULT")
  notes                    String?
  isActive                 Boolean      @default(true)

  // ── v3 확장 컬럼 ─────────────────────────────────────────
  contractKind             ContractKind?
  contractTemplateType     ContractTemplateType?
  contractStatus           ContractStatus        @default(DRAFT)
  serviceFee               Int?                  // 용역비 (원)
  paymentDay               Int?                  // 지급일 (1-31)
  standardWorkHours        Decimal?              @db.Decimal(4, 2)  // 소정근로시간 (일 기준)
  breakHours               Decimal?              @db.Decimal(4, 2)  // 휴게시간
  nationalPensionYn        Boolean               @default(false)
  healthInsuranceYn        Boolean               @default(false)
  employmentInsuranceYn    Boolean               @default(false)
  industrialAccidentYn     Boolean               @default(true)
  retirementMutualYn       Boolean               @default(false)
  specialTerms             String?               // 특약사항
  pdfFilePath              String?               // 생성된 PDF 경로
  signedAt                 DateTime?
  createdBy                String?               // AdminUser.id

  // ── v3.1 계약 분류 확장 ────────────────────────────────────
  laborRelationType        String?               // DIRECT_EMPLOYEE | SUBCONTRACT_BIZ | TEAM_NONBIZ_REVIEW
  businessRegistrationNo   String?               // 사업자등록번호 (외주팀)
  contractorName           String?               // 수급인 상호 (외주팀)
  safetyClauseYn           Boolean               @default(true)   // 안전보건 조항 포함
  checkInTime              String?               // 근무시작시각 'HH:MM'
  checkOutTime             String?               // 근무종료시각 'HH:MM'
  workDays                 String?               // 근무요일 문자열
  paymentMethod            String?               // 지급방법
  reviewFlags              String?               // 경고 플래그 (comma-separated)
  attendanceControlledByCompany Boolean?          // 회사가 출퇴근 직접 관리
  payDecidedByCompany      Boolean?              // 회사가 개인별 급여 직접 결정
  directPaymentByCompany   Boolean?              // 회사가 개인별 직접 지급

  // ── v3.3 계약서 완성 필드 ──────────────────────────────────
  // 사용자(회사) 기본정보
  companyBizNo             String?               // 사업자등록번호
  companyAddress           String?               // 사업장 주소
  companyRepName           String?               // 대표자명

  // 근로자 기본정보 (계약서 기입용)
  workerBirthDate          String?               // 생년월일 'YYYY-MM-DD'
  workerAddress            String?               // 근로자 주소

  // 근로시간 상세
  breakStartTime           String?               // 휴게 시작 'HH:MM'
  breakEndTime             String?               // 휴게 종료 'HH:MM'
  weeklyWorkDays           Int?                  // 주 소정근로일 (일)
  weeklyWorkHours          Decimal?              @db.Decimal(4, 2) // 주 소정근로시간

  // 휴일/연차
  holidayRule              String?               // 주휴일 (예: '일요일')
  annualLeaveRule          String?               // 연차유급휴가 적용 문구 요약

  // 임금 상세
  allowanceJson            Json?                 // 수당 항목 [{name, amount}]

  // 수습
  probationYn              Boolean               @default(false)
  probationMonths          Int?

  // 현장 특약
  attendanceVerificationMethod String?           // 출퇴근 인증 방식
  workUnitRule             String?               // 공수 인정 기준
  rainDayRule              String?               // 우천 시 처리 기준
  siteStopRule             String?               // 작업중지 시 처리 기준
  siteChangeAllowed        Boolean               @default(true)

  // 전자서명/교부
  electronicDeliveryConsent Boolean              @default(false)
  signedBy                 String?               // 서명자명
  deliveredAt              DateTime?
  deliveredMethod          String?               // EMAIL | KAKAO | PAPER | APP

  // 버전관리
  currentVersion           Int                   @default(1)

  // v3.4 — 공사·직종·계약형태
  projectName              String?               // 공사명
  workType                 String?               // 공종 (전기/소방전기/소방기계/기계설비/통신/기타)
  workTypeSub              String?               // 세부공종
  jobCategory              String?               // 직종 (보통인부/특별인부/조공/전공/기능공/기사반장/기타)
  jobCategorySub           String?               // 세부직종
  contractForm             String?               // MONTHLY_FIXED | CONTINUOUS
  taskDescription          String?               // 담당업무
  siteAddress              String?               // 현장 주소 (직접 입력)
  // ─────────────────────────────────────────────────────────

  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  worker             Worker              @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site               Site?               @relation(fields: [siteId], references: [id], onDelete: SetNull)
  generatedDocuments GeneratedDocument[]
  contractVersions   ContractVersion[]
  safetyDocuments    SafetyDocument[]

  @@index([workerId])
  @@index([siteId])
  @@index([startDate])
  @@index([contractStatus])
  @@map("worker_contracts")
}

model AttendanceDay {
  id                      String                      @id @default(cuid())
  workerId                String
  siteId                  String
  workDate                String   // 'YYYY-MM-DD'
  firstCheckInAt          DateTime?
  lastCheckOutAt          DateTime?
  workedMinutesRaw        Int?     // 레거시 — workedMinutesAuto와 동일값 유지
  workedMinutesAuto       Int?     // 시스템 자동 계산값 (원본 보존)
