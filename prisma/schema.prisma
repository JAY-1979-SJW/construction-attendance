  uploadedBy       String
  originalFilename String
  status           BulkImportJobStatus @default(PENDING)
  totalRows        Int                 @default(0)
  okRows           Int                 @default(0)
  reviewRows       Int                 @default(0)
  blockRows        Int                 @default(0)
  failedRows       Int                 @default(0)
  importedRows     Int                 @default(0)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  rows BulkWorkerImportRow[]

  @@index([createdAt])
  @@map("bulk_worker_import_jobs")
}

model BulkWorkerImportRow {
  id                  String                         @id @default(cuid())
  jobId               String
  rowNumber           Int
  // 원본 입력값
  name                String
  phone               String
  jobTitle            String
  employmentType      String?
  organizationType    String?
  birthDate           String?
  foreignerYn         Boolean                        @default(false)
  skillLevel          String?
  subcontractorName   String?
  note                String?
  // 정규화 결과
  normalizedPhone     String?
  normalizedName      String?
  normalizedBirth     String?
  // 중복 판정
  dedupeStatus        String                         @default("PENDING")   // OK, REVIEW, BLOCK, PENDING
  dedupeReason        String?
  matchedWorkerId     String?
  matchedWorkerName   String?
  candidatesJson      Json?                          // 후보 목록 JSON
  // AI 보조
  aiDecision          String?                        // SAME, DIFFERENT, UNCERTAIN
  aiConfidence        Float?
  aiExplanation       String?
  // 사용자 결정
  userDecision        String?                        // USE_EXISTING, REGISTER_NEW, CANCEL
