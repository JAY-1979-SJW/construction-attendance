// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum AttendanceStatus {
  WORKING           // 출근 후 미퇴근 (당일)
  COMPLETED         // 정상 출퇴근 완료
  MISSING_CHECKOUT  // 퇴근 미기록 (익일 04:00 스케줄러 전환)
  ADJUSTED          // 관리자가 시간 수정한 기록
  ADMIN_MANUAL      // 관리자가 직접 생성한 기록
  EXCEPTION         // 예외 처리 (GPS 실패 등 관리자 승인)
}

enum AttendanceEventType {
  CHECK_IN       // 출근
  MOVE           // 현장 이동 (이동형 근무)
  CHECK_OUT      // 퇴근
  AUTO_CHECK_OUT // 자동 퇴근 처리
}

enum DeviceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OtpPurpose {
  LOGIN
  DEVICE_CHANGE
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  VIEWER
}

enum TimeBucket {
  AM
  PM
}

enum PresenceCheckStatus {
  PENDING
  COMPLETED
  MISSED           // legacy, replaced by NO_RESPONSE
  OUT_OF_GEOFENCE
  LOW_ACCURACY     // legacy
  SKIPPED          // legacy
  NO_RESPONSE      // new: expired without response
  REVIEW_REQUIRED  // new: needs admin review
  CANCELED         // new: admin canceled
  MANUALLY_CONFIRMED  // new: admin approved as present
  MANUALLY_REJECTED   // new: admin confirmed absence/violation
}

// ─── 노무 관리 Enums (Phase 1) ────────────────────────────

enum EmploymentType {
  REGULAR              // 상용근로자
  DAILY_CONSTRUCTION   // 건설 일용근로자
  BUSINESS_33          // 3.3% 사업소득
  OTHER                // 기타
}

enum IncomeType {
  SALARY           // 급여 (상용)
  DAILY_WAGE       // 일용근로소득
  BUSINESS_INCOME  // 사업소득
}

enum OrganizationType {
  DIRECT         // 직영
  SUBCONTRACTOR  // 협력사 소속
}

enum ContractType {
  EMPLOYMENT  // 근로계약
  DAILY       // 일용계약
  SERVICE     // 용역계약 (3.3%)
}

enum WorkConfirmationStatus {
  DRAFT      // 확정 전 (초안)
  CONFIRMED  // 확정 완료
  EXCLUDED   // 제외 (무효)
}

enum ConfirmedWorkType {
  FULL_DAY   // 정규 1공수
  HALF_DAY   // 반일 0.5공수
  OVERTIME   // 연장근무
  NIGHT      // 야간근무
  HOLIDAY    // 휴일근무
  INVALID    // 무효 출역
}

enum AttendanceDayPresenceStatus {
  NORMAL           // 정상
  REVIEW_REQUIRED  // 검토 필요
  OUT_OF_GEOFENCE  // 위치이탈
  NO_RESPONSE      // 미응답
  MISSING_CHECKOUT // 퇴근 미기록
  INVALID          // 무효
}

enum FilingExportType {
  DAILY_WAGE_NTS         // 일용근로소득 지급명세서
  BUSINESS_INCOME_NTS    // 사업소득 간이지급명세서
  EI_DAILY_REPORT        // 고용보험 근로내용확인신고
  NP_BASE                // 국민연금 판정 기초
  HI_BASE                // 건강보험 판정 기초
  RETIREMENT_MUTUAL_BASE // 퇴직공제 기초
  LABOR_COST_SUMMARY     // 노무비 집계
}

enum MonthClosingStatus {
  OPEN
  CLOSING
  CLOSED
  REOPENED
}

enum ClosingScope {
  GLOBAL
  SITE
}

enum CorrectionDomainType {
  WORK_CONFIRMATION
  INSURANCE
  WAGE
  WITHHOLDING
  RETIREMENT_MUTUAL
  EXPORT
  MONTH_CLOSING
}

enum CorrectionActionType {
  CREATE
  UPDATE
  DELETE
  REOPEN
  RECALCULATE
  MANUAL_OVERRIDE
}

enum RetirementReportStatus {
  READY
  EXPORTED
  CORRECTED
}

// ─── Models ──────────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  processedDeviceRequests DeviceChangeRequest[] @relation("ProcessedBy")
  auditLogs               AdminAuditLog[]

  @@map("admin_users")
}

model Subcontractor {
  id             String   @id @default(cuid())
  name           String
  businessNumber String?  @unique
  contactName    String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workers            Worker[]
  laborCostSummaries LaborCostSummary[]

  @@map("subcontractors")
}

model Worker {
  id          String   @id @default(cuid())
  name        String
  phone       String   @unique
  company     String
  jobTitle    String
  isActive    Boolean  @default(true)

  // ── 노무 관리 확장 필드 (Phase 1) ──────────────────────
  residentIdMasked          String?
  foreignerYn               Boolean          @default(false)
  nationalityCode           String?          @default("KR")
  bankName                  String?
  bankAccount               String?
  employmentType            EmploymentType   @default(DAILY_CONSTRUCTION)
  incomeType                IncomeType       @default(DAILY_WAGE)
  organizationType          OrganizationType @default(DIRECT)
  subcontractorId           String?
  skillLevel                String?
  retirementMutualTargetYn  Boolean          @default(false)
  fourInsurancesEligibleYn  Boolean          @default(true)
  // ───────────────────────────────────────────────────────

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  devices              WorkerDevice[]
  attendanceLogs       AttendanceLog[]
  deviceChangeRequests DeviceChangeRequest[]
  otpVerifications     OtpVerification[]
  attendanceEvents     AttendanceEvent[]
  presenceChecks       PresenceCheck[]
  subcontractor        Subcontractor?              @relation(fields: [subcontractorId], references: [id], onDelete: SetNull)
  contracts            WorkerContract[]
  attendanceDays       AttendanceDay[]
  workConfirmations    MonthlyWorkConfirmation[]
  insuranceSnapshots   InsuranceEligibilitySnapshot[]
  wageCalculations     WageCalculation[]
  withholdingCalcs     WithholdingCalculation[]
  retirementRecords          RetirementMutualDailyRecord[]
  retirementMutualWorkers    RetirementMutualWorker[]
  retirementMonthlySummaries RetirementMutualMonthlySummary[]

  @@map("workers")
}

model Site {
  id             String   @id @default(cuid())
  name           String
  address        String
  latitude       Float
  longitude      Float
  allowedRadius  Int      @default(100) // meters
  qrToken        String   @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  checkInLogs    AttendanceLog[]   @relation("CheckInSite")
  checkOutLogs   AttendanceLog[]   @relation("CheckOutSite")
  events         AttendanceEvent[]
  presenceChecks PresenceCheck[]
  contracts      WorkerContract[]
  attendanceDays AttendanceDay[]
  workConfirmations          MonthlyWorkConfirmation[]
  retirementRecords          RetirementMutualDailyRecord[]
  monthClosings              MonthClosing[]
  retirementMutualSite       RetirementMutualSite?
  retirementMonthlySummaries RetirementMutualMonthlySummary[]
  laborCostSummaries         LaborCostSummary[]

  @@map("sites")
}

model WorkerDevice {
  id          String   @id @default(cuid())
  workerId    String
  deviceToken String   @unique
  deviceName  String
  isPrimary   Boolean  @default(false)
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_devices")
}

model OtpVerification {
  id          String     @id @default(cuid())
  phone       String
  code        String
  purpose     OtpPurpose
  expiresAt   DateTime
  verifiedAt  DateTime?
  createdAt   DateTime   @default(now())

  workerId String?
  worker   Worker? @relation(fields: [workerId], references: [id], onDelete: SetNull)

  @@map("otp_verifications")
}

model AttendanceLog {
  id              String           @id @default(cuid())
  workerId        String
  siteId          String
  checkOutSiteId  String?
  workDate        DateTime         @db.Date
  checkInAt       DateTime?
  checkOutAt      DateTime?
  checkInLat      Float?
  checkInLng      Float?
  checkOutLat     Float?
  checkOutLng     Float?
  checkInDistance Float?
  checkOutDistance Float?
  qrToken         String
  status          AttendanceStatus @default(WORKING)
  exceptionReason String?
  adminNote       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  worker        Worker  @relation(fields: [workerId], references: [id])
  checkInSite   Site    @relation("CheckInSite", fields: [siteId], references: [id])
  checkOutSite  Site?   @relation("CheckOutSite", fields: [checkOutSiteId], references: [id])
  events         AttendanceEvent[]
  presenceChecks PresenceCheck[]

  @@unique([workerId, siteId, workDate])
  @@index([workDate])
  @@index([siteId, workDate])
  @@map("attendance_logs")
}

model AttendanceEvent {
  id               String              @id @default(cuid())
  attendanceLogId  String
  workerId         String
  eventType        AttendanceEventType
  siteId           String?
  occurredAt       DateTime            @default(now())
  latitude         Float?
  longitude        Float?
  accuracy         Float?
  distanceFromSite Float?
  deviceId         String?
  memo             String?

  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  worker        Worker        @relation(fields: [workerId], references: [id])
  site          Site?         @relation(fields: [siteId], references: [id])

  @@index([attendanceLogId])
  @@index([workerId, occurredAt])
  @@map("attendance_events")
}

model DeviceChangeRequest {
  id             String              @id @default(cuid())
  workerId       String
  oldDeviceToken String?
  newDeviceToken String
  newDeviceName  String
  reason         String
  status         DeviceRequestStatus @default(PENDING)
  requestedAt    DateTime            @default(now())
  processedAt    DateTime?
  processedBy    String?

  worker    Worker     @relation(fields: [workerId], references: [id])
  adminUser AdminUser? @relation("ProcessedBy", fields: [processedBy], references: [id])

  @@map("device_change_requests")
}

model AppSettings {
  id                                String   @id @default("singleton")
  planType                          String   @default("FREE")
  presenceCheckFeatureAvailable     Boolean  @default(false)
  presenceCheckEnabled              Boolean  @default(false)
  presenceCheckAmEnabled            Boolean  @default(true)
  presenceCheckPmEnabled            Boolean  @default(true)
  presenceCheckRadiusMeters         Int      @default(30)
  presenceCheckResponseLimitMinutes Int      @default(20)
  presenceCheckFailureNeedsReview   Boolean  @default(true)
  presenceCheckAmStart              String   @default("09:30")
  presenceCheckAmEnd                String   @default("11:30")
  presenceCheckPmStart              String   @default("13:30")
  presenceCheckPmEnd                String   @default("16:30")
  updatedAt                         DateTime @updatedAt

  @@map("app_settings")
}

model PresenceCheck {
  id                  String              @id @default(cuid())
  workerId            String
  attendanceLogId     String
  siteId              String
  checkDate           String
  timeBucket          TimeBucket
  scheduledAt         DateTime
  expiresAt           DateTime
  status              PresenceCheckStatus @default(PENDING)
  respondedAt         DateTime?
  latitude            Float?
  longitude           Float?
  accuracyMeters      Float?
  distanceMeters      Float?
  appliedRadiusMeters Int?
  needsReview         Boolean             @default(false)
  reviewReason        String?
  reviewedBy          String?
  reviewedAt          DateTime?
  adminNote           String?
  reissuedFromId      String?
  reissueCount        Int                 @default(0)
  closedAt            DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  worker        Worker        @relation(fields: [workerId], references: [id])
  attendanceLog AttendanceLog @relation(fields: [attendanceLogId], references: [id], onDelete: Cascade)
  site          Site          @relation(fields: [siteId], references: [id])
  auditLogs     PresenceCheckAuditLog[]

  @@unique([attendanceLogId, checkDate, timeBucket])
  @@index([workerId, scheduledAt])
  @@index([attendanceLogId])
  @@index([status])
  @@index([scheduledAt])

  @@map("presence_checks")
}

model PresenceCheckAuditLog {
  id                String   @id @default(cuid())
  presenceCheckId   String
  action            String
  actorType         String
  actorId           String?
  actorNameSnapshot String?
  fromStatus        String?
  toStatus          String?
  message           String?
  metadataJson      Json?
  createdAt         DateTime @default(now())

  presenceCheck PresenceCheck @relation(fields: [presenceCheckId], references: [id], onDelete: Cascade)

  @@index([presenceCheckId])
  @@index([createdAt])
  @@map("presence_check_audit_logs")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  actionType  String
  targetType  String?
  targetId    String?
  description String
  createdAt   DateTime @default(now())
  ipAddress   String?

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_audit_logs")
}

// ─── 노무 관리 Models (Phase 1) ───────────────────────────

model WorkerContract {
  id                       String       @id @default(cuid())
  workerId                 String
  siteId                   String?
  contractType             ContractType @default(DAILY)
  startDate                String       // 'YYYY-MM-DD'
  endDate                  String?
  dailyWage                Int          @default(0)
  monthlySalary            Int?
  hourlyRate               Int?
  overtimeRate             Decimal?     @db.Decimal(4, 2)  // 배율 (예: 1.5)
  nightRate                Decimal?     @db.Decimal(4, 2)
  holidayRate              Decimal?     @db.Decimal(4, 2)
  halfDayRule              String       @default("HALF")   // HALF | QUARTER
  taxRuleType              String       @default("DAILY_WAGE")
  insuranceRuleType        String       @default("DEFAULT")
  retirementMutualRuleType String       @default("DEFAULT")
  notes                    String?
  isActive                 Boolean      @default(true)
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  worker Worker  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site   Site?   @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@index([workerId])
  @@index([siteId])
  @@index([startDate])
  @@map("worker_contracts")
}

model AttendanceDay {
  id                      String                      @id @default(cuid())
  workerId                String
  siteId                  String
  workDate                String   // 'YYYY-MM-DD'
  firstCheckInAt          DateTime?
  lastCheckOutAt          DateTime?
  workedMinutesRaw        Int?
  presenceStatus          AttendanceDayPresenceStatus @default(NORMAL)
  presenceReviewResult    String?
  attendanceSourceSummary Json?
  hasMoveBetweenSites     Boolean  @default(false)
  manualAdjustedYn        Boolean  @default(false)
  manualAdjustedReason    String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Restrict)
  workConfirmations MonthlyWorkConfirmation[]

  @@unique([workerId, siteId, workDate])
  @@index([workerId, workDate])
  @@index([siteId, workDate])
  @@map("attendance_days")
}

model MonthlyWorkConfirmation {
  id                              String                 @id @default(cuid())
  workerId                        String
  siteId                          String
  workDate                        String   // 'YYYY-MM-DD'
  monthKey                        String   // 'YYYY-MM'
  attendanceDayId                 String?
  confirmationStatus              WorkConfirmationStatus @default(DRAFT)
  confirmedWorkType               ConfirmedWorkType?
  confirmedWorkUnits              Decimal  @default(0) @db.Decimal(4, 2) // 0.5, 1.0, 1.5...
  confirmedWorkMinutes            Int      @default(0)
  confirmedBaseAmount             Int      @default(0)
  confirmedAllowanceAmount        Int      @default(0)
  confirmedTotalAmount            Int      @default(0)
  incomeTypeSnapshot              String?
  employmentTypeSnapshot          String?
  retirementMutualTargetSnapshot  Boolean?
  insuranceReviewSnapshotJson     Json?
  confirmedBy                     String?  // AdminUser.id
  confirmedAt                     DateTime?
  notes                           String?
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  worker        Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site          Site          @relation(fields: [siteId], references: [id], onDelete: Restrict)
  attendanceDay AttendanceDay? @relation(fields: [attendanceDayId], references: [id], onDelete: SetNull)
  retirementRecords RetirementMutualDailyRecord[]

  @@unique([workerId, siteId, workDate])
  @@index([workerId, monthKey])
  @@index([siteId, monthKey])
  @@index([monthKey])
  @@map("monthly_work_confirmations")
}

model InsuranceEligibilitySnapshot {
  id                           String  @id @default(cuid())
  workerId                     String
  monthKey                     String  // 'YYYY-MM'
  totalWorkDays                Int     @default(0)
  totalConfirmedAmount         Int     @default(0)
  nationalPensionEligible      Boolean @default(false)
  nationalPensionReason        String?
  healthInsuranceEligible      Boolean @default(false)
  healthInsuranceReason        String?
  employmentInsuranceEligible  Boolean @default(false)
  employmentInsuranceReason    String?
  industrialAccidentEligible   Boolean @default(true)
  industrialAccidentReason     String?
  calculationSnapshotJson      Json?
  createdAt                    DateTime @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, monthKey])
  @@index([monthKey])
  @@map("insurance_eligibility_snapshots")
}

model WageCalculation {
  id                      String     @id @default(cuid())
  workerId                String
  monthKey                String     // 'YYYY-MM'
  incomeType              IncomeType
  regularDays             Decimal    @default(0) @db.Decimal(6, 2)
  halfDays                Decimal    @default(0) @db.Decimal(6, 2)
  overtimeMinutes         Int        @default(0)
  nightMinutes            Int        @default(0)
  holidayMinutes          Int        @default(0)
  grossAmount             Int        @default(0)
  nonTaxableAmount        Int        @default(0)
  taxableAmount           Int        @default(0)
  calculationSnapshotJson Json?
  createdAt               DateTime   @default(now())

  worker          Worker               @relation(fields: [workerId], references: [id], onDelete: Cascade)
  withholdingCalc WithholdingCalculation?

  @@unique([workerId, monthKey])
  @@index([monthKey])
  @@map("wage_calculations")
}

model WithholdingCalculation {
  id                   String     @id @default(cuid())
  workerId             String
  monthKey             String     // 'YYYY-MM'
  incomeType           IncomeType
  grossAmount          Int        @default(0)
  incomeTaxAmount      Int        @default(0)
  localIncomeTaxAmount Int        @default(0)
  formulaCode          String     // DAILY_WAGE_2024 | BUSINESS_33 | SALARY_TABLE
  formulaSnapshotJson  Json?
  wageCalculationId    String?    @unique
  createdAt            DateTime   @default(now())

  worker          Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  wageCalculation WageCalculation? @relation(fields: [wageCalculationId], references: [id], onDelete: SetNull)

  @@unique([workerId, monthKey])
  @@index([monthKey])
  @@map("withholding_calculations")
}

model RetirementMutualDailyRecord {
  id                   String  @id @default(cuid())
  workerId             String
  siteId               String
  workDate             String  // 'YYYY-MM-DD'
  monthKey             String  // 'YYYY-MM'
  eligibleYn            Boolean  @default(true)
  recognizedWorkUnit    Decimal  @default(1.0) @db.Decimal(4, 2)
  sourceConfirmationId  String?
  reason                String?
  excludedReason        String?
  manualOverrideYn      Boolean  @default(false)
  manualOverrideReason  String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  worker       Worker                  @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site         Site                    @relation(fields: [siteId], references: [id], onDelete: Restrict)
  confirmation MonthlyWorkConfirmation? @relation(fields: [sourceConfirmationId], references: [id], onDelete: SetNull)

  @@unique([workerId, siteId, workDate])
  @@index([workerId, monthKey])
  @@index([monthKey])
  @@map("retirement_mutual_daily_records")
}

model FilingExport {
  id                    String           @id @default(cuid())
  monthKey              String           // 'YYYY-MM'
  exportType            FilingExportType
  status                String           @default("PENDING") // PENDING | COMPLETED | FAILED
  filePath              String?
  rowCount              Int              @default(0)
  snapshotJson          Json?
  createdBy             String?          // AdminUser.id
  createdAt             DateTime         @default(now())
  monthClosingId        String?
  versionNo             Int              @default(1)
  isLatestYn            Boolean          @default(true)
  outdatedYn            Boolean          @default(false)
  exportScopeJson       Json?
  generatedSnapshotJson Json?

  monthClosing MonthClosing? @relation(fields: [monthClosingId], references: [id], onDelete: SetNull)

  @@index([monthKey])
  @@index([exportType])
  @@map("filing_exports")
}

// ─── 노무 관리 Models (Phase 3) ───────────────────────────

model MonthClosing {
  id                          String             @id @default(cuid())
  monthKey                    String             // 'YYYY-MM'
  siteId                      String?
  closingScope                ClosingScope       @default(GLOBAL)
  status                      MonthClosingStatus @default(OPEN)
  precheckPassedYn            Boolean            @default(false)
  workConfirmationLockedYn    Boolean            @default(false)
  insuranceLockedYn           Boolean            @default(false)
  wageLockedYn                Boolean            @default(false)
  retirementMutualLockedYn    Boolean            @default(false)
  closedBy                    String?
  closedAt                    DateTime?
  reopenedBy                  String?
  reopenedAt                  DateTime?
  reopenReason                String?
  createdAt                   DateTime           @default(now())
  updatedAt                   DateTime           @updatedAt

  site          Site?          @relation(fields: [siteId], references: [id], onDelete: SetNull)
  filingExports FilingExport[]

  @@unique([monthKey, closingScope, siteId])
  @@index([monthKey])
  @@map("month_closings")
}

model RetirementMutualSite {
  id                      String   @id @default(cuid())
  siteId                  String   @unique
  enabledYn               Boolean  @default(false)
  projectType             String?
  contractAmount          BigInt?
  recognitionRuleType     String   @default("DEFAULT")
  halfDayRecognitionRule  String   @default("INCLUDE")  // INCLUDE | EXCLUDE
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("retirement_mutual_sites")
}

model RetirementMutualWorker {
  id        String   @id @default(cuid())
  workerId  String
  enabledYn Boolean  @default(true)
  startDate String   // 'YYYY-MM-DD'
  endDate   String?
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@map("retirement_mutual_workers")
}

model RetirementMutualMonthlySummary {
  id                  String                 @id @default(cuid())
  workerId            String
  siteId              String
  monthKey            String
  recognizedWorkDays  Int                    @default(0)
  recognizedWorkUnits Decimal                @default(0) @db.Decimal(6, 2)
  eligibleYn          Boolean                @default(true)
  reportStatus        RetirementReportStatus @default(READY)
  snapshotJson        Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Restrict)

  @@unique([workerId, siteId, monthKey])
  @@index([monthKey])
  @@map("retirement_mutual_monthly_summaries")
}

model CorrectionLog {
  id          String               @id @default(cuid())
  domainType  CorrectionDomainType
  domainId    String
  actionType  CorrectionActionType
  beforeJson  Json?
  afterJson   Json?
  reason      String?
  actedBy     String?
  actedAt     DateTime             @default(now())

  @@index([domainType, domainId])
  @@index([actedAt])
  @@map("correction_logs")
}

model LaborCostSummary {
  id                              String           @id @default(cuid())
  monthKey                        String
  siteId                          String
  organizationType                OrganizationType
  subcontractorId                 String?
  workerCount                     Int              @default(0)
  confirmedWorkUnits              Decimal          @default(0) @db.Decimal(10, 2)
  grossAmount                     Int              @default(0)
  taxableAmount                   Int              @default(0)
  withholdingTaxAmount            Int              @default(0)
  nationalPensionTargetCount      Int              @default(0)
  healthInsuranceTargetCount      Int              @default(0)
  employmentInsuranceTargetCount  Int              @default(0)
  retirementMutualTargetDays      Int              @default(0)
  createdAt                       DateTime         @default(now())

  site          Site           @relation(fields: [siteId], references: [id], onDelete: Restrict)
  subcontractor Subcontractor? @relation(fields: [subcontractorId], references: [id], onDelete: SetNull)

  @@index([monthKey])
  @@index([siteId, monthKey])
  @@map("labor_cost_summaries")
}
