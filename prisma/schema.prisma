  sensitiveProfile           WorkerSensitiveProfile?
  bankAccountSecure          WorkerBankAccountSecure?
  complianceStatus           WorkerComplianceStatus?
  tempDocuments              TempSensitiveDocument[]
  // v3 — 근로형태 분류
  profile                    WorkerProfile?
  generatedDocuments         GeneratedDocument[]
  safetyDocuments            SafetyDocument[]
  // 분쟁방어 패널
  disputeCases               DisputeCase[]
  defensePanelSnapshots      DefensePanelSnapshot[]
  documentDeliveryLogs       DocumentDeliveryLog[]
  attendanceAdjustmentLogs   AttendanceAdjustmentLog[]
  workerRequests             WorkerRequest[]
