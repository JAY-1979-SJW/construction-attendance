// ─── 현장별 근무시간·휴게시간 정책 ────────────────────────────

// 현장별 출퇴근·휴게 운영 정책
// null 값 = 회사 기본값 사용 (COMPANY_DEFAULT_* 상수)
// 실제 적용값은 resolveEffectiveSiteAttendancePolicy(siteId) 를 통해 조회
// 공수 계산에 직접 영향: breakMinutes / workStartTime·workEndTime 은 표시용
model SiteAttendancePolicy {
  id             String   @id @default(cuid())
  siteId         String   @unique

  workStartTime  String?  // 출근 기준 시각 (HH:mm, 표시용) e.g. "07:00"
  workEndTime    String?  // 퇴근 기준 시각 (HH:mm, 표시용) e.g. "17:00"
  breakStartTime String?  // 휴게 시작 시각 (HH:mm, 표시용) e.g. "12:00"
  breakEndTime   String?  // 휴게 종료 시각 (HH:mm, 표시용) e.g. "13:00"
  breakMinutes   Int?     // 공수 계산 차감 휴게시간(분), null = 회사 기본값 60분

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@map("site_attendance_policies")
}

// ─── 현장별 문서 정책 (어떤 문서가 필수/선택인지) ────────────
// 현장마다 요구 서류가 다를 수 있으므로 현장 단위로 관리
// 레코드가 없으면 REQUIRED_DOC_TYPES 전체 필수(기존 동작 유지)
model SiteDocumentPolicy {
  id          String          @id @default(cuid())
  siteId      String
  docType     OnboardingDocType
  isRequired  Boolean         @default(true)   // true=필수, false=선택
  isActive    Boolean         @default(true)    // false면 아예 생성 안 함
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  site        Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, docType])
  @@index([siteId])
  @@map("site_document_policies")
}

// ─── v2: Worker-Company 소속 이력 ─────────────────────────

model WorkerCompanyAssignment {
