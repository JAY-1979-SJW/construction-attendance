// ─── 민감 개인정보 분리보관 (AES-256-GCM 암호화) ────────────
// 주민등록번호, 휴대폰번호, 주소 — 출퇴근 앱과 별도 보안 흐름
// 신분증 파일은 저장하지 않음 (본사/노무 담당자 외부 보안 절차로 수집 후 확인 결과만 기록)

model WorkerSensitiveProfile {
  id                  String              @id @default(cuid())
  workerId            String              @unique

  // 법적 성명 (한글 전체명)
  legalName           String?

  // 주민등록번호 — 원문은 암호화 저장, 마스킹은 화면용, 해시는 중복검색용
  rrnEncrypted        String?             // AES-256-GCM 암호화값
  rrnMasked           String?             // "800101-1******"
  rrnHash             String?             // HMAC-SHA256 (중복검색용)

  // 휴대폰번호 원문 (Worker.phone은 마스킹 저장용 — 이쪽이 원문)
  phoneEncrypted      String?             // AES-256-GCM
  phoneMasked         String?             // "010-12**-5678"
  phoneHash           String?             // HMAC-SHA256

  // 주소
  addressEncrypted    String?             // AES-256-GCM
  addressMasked       String?             // "서울 강남구 ***"

  // 신분증 확인 결과 (파일은 저장 안 함)
  idVerified          Boolean             @default(false)
  idDocumentType      String?             // "주민등록증" | "운전면허증" | "외국인등록증"
  idVerificationMethod IdVerificationMethod?
  idVerifiedBy        String?             // AdminUser.id
  idVerifiedAt        DateTime?
  idVerificationNote  String?             // 확인 메모

  // 수집/확인 이력
  collectedBy         String?             // AdminUser.id
  collectedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([rrnHash])
  @@index([phoneHash])
  @@map("worker_sensitive_profiles")
}

model WorkerBankAccountSecure {
  id                         String   @id @default(cuid())
  workerId                   String   @unique

  bankCode                   String?  // 은행 코드 (예: "004" = 국민은행)
  bankName                   String?  // 은행명 (화면 표시용)

  // 계좌번호 — 원문 암호화, 마스킹, 해시
  accountNumberEncrypted     String?  // AES-256-GCM
  accountNumberMasked        String?  // "****5678"
  accountNumberHash          String?  // HMAC-SHA256 (중복검색용)

  // 예금주명
  accountHolderNameEncrypted String?  // AES-256-GCM
  accountHolderNameMasked    String?  // 마스킹

  // 확인 이력
  verifiedBy                 String?  // AdminUser.id
  verifiedAt                 DateTime?
  collectedBy                String?
  collectedAt                DateTime?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_bank_accounts_secure")
}

model WorkerComplianceStatus {
  id                      String                @id @default(cuid())
  workerId                String                @unique

  // 신원 확인
  basicIdentityChecked    Boolean               @default(false)  // 기본 신원 확인 완료
  rrnCollected            Boolean               @default(false)  // 주민등록번호 수집 완료
  addressCollected        Boolean               @default(false)  // 주소 수집 완료
  bankInfoCollected       Boolean               @default(false)  // 계좌정보 수집 완료

  // 보험 신고 상태
  nationalPensionStatus   ComplianceReadyStatus @default(NOT_STARTED)   // 국민연금
  healthInsuranceStatus   ComplianceReadyStatus @default(NOT_STARTED)   // 건강보험
  employmentInsuranceStatus ComplianceReadyStatus @default(NOT_STARTED) // 고용보험
  industrialAccidentStatus  ComplianceReadyStatus @default(NOT_STARTED) // 산재보험

  // 퇴직공제
  retirementMutualStatus  ComplianceReadyStatus @default(NOT_STARTED)

  // 메모
  notes                   String?
  updatedBy               String?   // 마지막 수정 AdminUser.id
  updatedAt               DateTime  @updatedAt
  createdAt               DateTime  @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_compliance_statuses")
}

// ─── 보험요율 버전 관리 ────────────────────────────────────

enum InsuranceRateType {
  NATIONAL_PENSION        // 국민연금
  HEALTH_INSURANCE        // 건강보험
  LONG_TERM_CARE          // 장기요양보험 (건강보험료의 %)
  EMPLOYMENT_INSURANCE    // 고용보험 (실업급여)
  EMPLOYMENT_STABILITY    // 고용안정·직업능력개발 (사업주만)
  INDUSTRIAL_ACCIDENT     // 산재보험 (업종별)
  RETIREMENT_MUTUAL       // 건설업 퇴직공제
}

enum InsuranceRateVersionStatus {
  DRAFT             // 초안 (작성 중)
  REVIEW_PENDING    // 검토 요청됨
  REVIEWED          // 검토 완료 (승인 전)
  APPROVED_FOR_USE  // 사용 승인 (시스템 적용)
  DEPRECATED        // 구버전 (더 이상 사용 안 함)
}

enum TempDocEventType {
  UPLOADED    // 업로드
  DOWNLOADED  // 다운로드 (사유 기록 필수)
  DELETED     // 삭제 (관리자 수동)
  AUTO_DELETED // 자동 삭제 (5일 초과 or 다운로드 후 24h)
  EXPIRED     // 만료 처리 (삭제 전 상태)
}

model InsuranceRateVersion {
  id                       String                     @id @default(cuid())
  rateType                 InsuranceRateType
  effectiveYear            Int                        // 적용 연도 (예: 2026)
  effectiveMonth           Int?                       // 적용 월 (null = 연간 요율)

  // 요율 (%)
  totalRatePct             Decimal?   @db.Decimal(6,4)  // 합산 요율
  employeeRatePct          Decimal?   @db.Decimal(6,4)  // 근로자 부담
  employerRatePct          Decimal?   @db.Decimal(6,4)  // 사업주 부담

  // 산재·퇴직공제: 업종별/지수별 메모
  rateNote                 String?    // 보조 설명 (업종별 차등 등)
  industryCode             String?    // 업종 코드 (산재보험 전용)

  // 공식 고시 출처
  officialSourceName       String?    // 고시 기관명 (예: "보건복지부")
  officialSourceUrl        String?    // 고시 URL
  officialAnnouncementDate DateTime?  // 고시 발표일
  referenceDocumentNo      String?    // 고시 번호

  // 워크플로 상태
  status                   InsuranceRateVersionStatus @default(DRAFT)
  reviewNote               String?
  reviewedBy               String?    // AdminUser.id
  reviewedAt               DateTime?
  approvedBy               String?    // AdminUser.id
  approvedAt               DateTime?
  deprecatedAt             DateTime?

  createdBy                String?    // AdminUser.id
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@index([rateType, effectiveYear])
  @@index([status])
  @@map("insurance_rate_versions")
}

model InsuranceRateSource {
  id                       String            @id @default(cuid())
  rateType                 InsuranceRateType @unique

  sourceName               String            // 공식 기관명 (예: "국민건강보험공단")
  sourceUrl                String            // 모니터링 URL
  checkFrequencyDays       Int               @default(30)   // 확인 주기 (일)

  lastCheckedAt            DateTime?          // 마지막 확인 일시
  lastChangeDetectedAt     DateTime?          // 마지막 변경 감지 일시
  currentRateNote          String?            // 마지막으로 파악한 요율 메모
  isActive                 Boolean            @default(true)

  notes                    String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@map("insurance_rate_sources")
}

// ─── 임시 민감 서류 (5일 자동삭제) ───────────────────────

model TempSensitiveDocument {
  id            String    @id @default(cuid())
  workerId      String
  documentType  String    // "ID_COPY" | "INSURANCE_CERT" | "CONTRACT" | "OTHER"
  purpose       String    // 업로드 목적 (필수)

  // 파일 정보
  fileName      String
  fileSize      Int       // bytes
  mimeType      String
  filePath      String    // 서버 내부 경로 (공개 URL 아님)

  // 수명 관리
  expiresAt     DateTime  // 업로드 후 최대 5일
  downloadedAt  DateTime? // 최초 다운로드 시각
  deleteScheduledAt DateTime? // 다운로드 후 24h (자동 업데이트)
  deletedAt     DateTime? // 실제 삭제 시각
  deleteReason  String?   // 삭제 사유 (자동삭제 / 관리자 수동)

  uploadedBy    String    // AdminUser.id
  uploadedAt    DateTime  @default(now())
  createdAt     DateTime  @default(now())

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
  events TempSensitiveDocumentEvent[]

  @@index([workerId])
  @@index([expiresAt])
  @@index([deleteScheduledAt])
  @@map("temp_sensitive_documents")
}

model TempSensitiveDocumentEvent {
  id           String           @id @default(cuid())
  documentId   String
  eventType    TempDocEventType
  actorUserId  String?          // AdminUser.id (시스템 자동 삭제 시 null)
  actorType    String           @default("ADMIN") // ADMIN | SYSTEM
  reason       String?          // 다운로드 시 필수 (5자 이상)
  ipAddress    String?
  metadataJson Json?
  createdAt    DateTime         @default(now())

  document TempSensitiveDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([createdAt])
  @@map("temp_sensitive_document_events")
}

// ═══════════════════════════════════════════════════════════
//  v3 — 근로형태 분류 · 계약 · 문서 생성
// ═══════════════════════════════════════════════════════════

// ── 근로자 분류 프로필 (Worker 1:1) ─────────────────────────
model WorkerProfile {
  id                    String               @id @default(cuid())
  workerId              String               @unique
  workerClass           WorkerClass          @default(EMPLOYEE)
  employmentMode        EmploymentMode       @default(DAILY)
  taxMode               TaxMode              @default(DAILY_WAGE)
  insuranceMode         InsuranceMode        @default(AUTO_RULE)
  officeWorkerYn        Boolean              @default(false)
  continuousWorkReview  ContinuousWorkReview @default(OK)
  classificationNote    String?              // 관리자 판단 메모

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@map("worker_profiles")
}

// ── 생성 문서 이력 ───────────────────────────────────────────
model GeneratedDocument {
  id           String                @id @default(cuid())
  workerId     String
  contractId   String?               // worker_contracts.id (계약서 PDF 시)
  documentType GeneratedDocumentType
  filePath     String                @default("")
  fileName     String
  fileHash     String?               // SHA-256
  mimeType     String                @default("application/pdf")
  contentText  String?               // 렌더링된 문서 텍스트 (미리보기용)
  contentJson  Json?                 // 렌더링된 문서 구조체 (섹션 배열)
  status       String                @default("DRAFT")  // DRAFT | ISSUED | SIGNED
  generatedAt  DateTime              @default(now())
  generatedBy  String                // AdminUser.id

  worker   Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  contract WorkerContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([workerId])
  @@index([contractId])
  @@index([documentType])
  @@map("generated_documents")
}

// ── 계약서 버전 이력 ─────────────────────────────────────────
model ContractVersion {
  id             String   @id @default(cuid())
  contractId     String
  versionNo      Int
  snapshotJson   Json     // 계약서 전체 데이터 스냅샷
  changeNote     String?  // 변경 사유
  draftDocId     String?  // generated_documents.id (초안)
  signedDocId    String?  // generated_documents.id (서명본)
  deliveredDocId String?  // generated_documents.id (교부본)
  createdBy      String   // AdminUser.id
  createdAt      DateTime @default(now())

  contract WorkerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, versionNo])
  @@index([contractId])
  @@map("contract_versions")
}

// ── 안전문서 ─────────────────────────────────────────────────
model SafetyDocument {
  id              String               @id @default(cuid())
  workerId        String
  siteId          String?
  contractId      String?
  documentType    SafetyDocumentType
  status          SafetyDocumentStatus @default(DRAFT)

  // 공통
  documentDate    String?              // 문서 작성일 'YYYY-MM-DD'
  educatorName    String?              // 교육 담당자 / 지급자
  educationPlace  String?              // 교육 장소

  // 안전교육 공통
  educationDate   String?              // 교육일 'YYYY-MM-DD'
  educationHours  Decimal?             @db.Decimal(4, 2)
  educationItems  Json?                // 교육 내용 항목 [{item, checked}]

  // 작업변경
  prevTask        String?              // 이전 작업
  newTask         String?              // 변경 후 작업

  // 보호구 지급
  issuedItemsJson Json?                // [{name, standard, qty, condition}]
  issuedBy        String?

  // 문서 내용
  contentText     String?
  contentJson     Json?

  // 서명/교부
  signedAt        DateTime?
  signedBy        String?              // 서명자명
  fileId          String?              // generated_documents.id

  // 검토/승인
  reviewedAt      DateTime?
  reviewedBy      String?              // AdminUser.id
  rejectReason    String?              // 반려 사유
  previousDocId   String?              // 재작성 시 이전(반려) 문서 ID
  expiresAt       DateTime?            // 서류 유효기간 만료일

  createdBy       String               // AdminUser.id
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  worker   Worker          @relation(fields: [workerId], references: [id], onDelete: Cascade)
  site     Site?           @relation(fields: [siteId], references: [id], onDelete: SetNull)
  contract WorkerContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([workerId])
  @@index([siteId])
  @@index([contractId])
  @@index([documentType])
  @@map("safety_documents")
}

