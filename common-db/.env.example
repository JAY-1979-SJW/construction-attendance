# common-db 환경변수 예시
# 실제 서버에서는 이 파일을 복사해 .env 로 만든 후 실제 값을 입력한다.
# .env 는 .gitignore 에 포함 — 절대 Git에 커밋하지 말 것.

# PostgreSQL 관리자 계정 비밀번호 (POSTGRES_USER=common_admin)
COMMON_ADMIN_PASSWORD=change_me_strong_password

# 갱신 스케줄러 전용 계정 비밀번호
COMMON_WRITER_PASSWORD=change_me_writer_password

# 조회 전용 계정 비밀번호
COMMON_READER_PASSWORD=change_me_reader_password
